# one.seil.space configuration
# Zkopíruj jako .env a vyplň. .env nikdy necommituj do gitu.

# Web server
PORT=3000
HOST=0.0.0.0

# Session secret - musí mít alespoň 32 znaků, v produkci vygeneruj náhodný řetězec
SESSION_SECRET=change-this-to-a-random-32char-secret-in-production

# Cesta k souboru s aktuálními statistikami a historickou DB.
# Collector tam zapisuje, web app odsud čte.
# Při běhu v Dockeru tohle bude bind-mount na hostový adresář.
STATS_DIR=/var/lib/vps-stats

# Timezone pro displej v UI
TZ=Europe/Prague

# Log level (fatal, error, warn, info, debug, trace)
LOG_LEVEL=info
