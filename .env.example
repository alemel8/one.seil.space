# one.seil.space configuration
# Zkopíruj jako .env a vyplň. .env nikdy necommituj do gitu.

# ── Server ────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=production
# Nastav na true jen pokud běžíš za HTTPS (Coolify/produkce)
COOKIE_SECURE=false

# Session secret — musí mít alespoň 32 znaků
SESSION_SECRET=change-this-to-a-random-32char-secret-in-production

# ── Databáze (PostgreSQL) ─────────────────────────────────────
# Produkce (VPS databáze seil):
DATABASE_URL=postgresql://seil:HESLO@89.221.219.220:5432/seil
# SSL pro vzdálené spojení (nastav true pokud PG vyžaduje SSL):
DATABASE_SSL=false

# ── Monitoring (VPS stats collector) ─────────────────────────
STATS_DIR=/var/lib/vps-stats
TZ=Europe/Prague
LOG_LEVEL=info

# ── Toneráček e-shop ──────────────────────────────────────────
# API klíč pro příjem objednávek přes /api/toneracek/* (Bearer token)
TONERACEK_API_KEY=XXXXXXXXXXXXXXXX

# ── E-mail (Resend) ───────────────────────────────────────────
RESEND_API_KEY=re_XXXXXXXXXXXXXXXX
