{
  "name": "one-seil-space",
  "version": "0.1.0",
  "description": "Internal VPS monitoring dashboard for seil.space infrastructure",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node --env-file=.env src/server.js",
    "dev": "node --env-file=.env --watch src/server.js",
    "collect": "node --env-file=.env src/collector.js",
    "superuser": "node --env-file=.env scripts/create-superuser.js",
    "migrate:sqlite": "node --env-file=.env scripts/migrate-sqlite-to-postgres.js",
    "migrate:orders": "node --env-file=.env scripts/migrate-airtable-orders.js",
    "test": "node --test test/"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@fastify/basic-auth": "^6.2.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/formbody": "^8.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/session": "^11.1.1",
    "@fastify/static": "^8.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@fastify/view": "^10.0.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.3.0",
    "connect-pg-simple": "^10.0.0",
    "ejs": "^3.1.10",
    "express-session": "^1.19.0",
    "fastify": "^5.0.0",
    "pg": "^8.21.0",
    "postgres": "^3.4.9",
    "puppeteer": "^24.43.1",
    "resend": "^6.12.3"
  },
  "devDependencies": {
    "@types/node": "^22.7.4"
  },
  "license": "UNLICENSED",
  "private": true
}
