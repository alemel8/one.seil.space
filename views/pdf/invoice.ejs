<!DOCTYPE html>
<html lang="cs">
<head>
<meta charset="UTF-8">
<style>
  * { margin:0; padding:0; box-sizing:border-box; }
  body { font-family: 'Helvetica Neue', Arial, sans-serif; font-size:10pt; color:#1a1a1a; }
  .page { padding:0; }

  /* Hlavička */
  .header { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:32px; }
  .company-logo { font-size:22pt; font-weight:700; color:#00AEC4; letter-spacing:-0.5px; }
  .invoice-title { text-align:right; }
  .invoice-title h1 { font-size:18pt; font-weight:700; color:#1a1a1a; margin-bottom:4px; }
  .invoice-title .number { font-size:14pt; color:#00AEC4; font-weight:600; }

  /* Adresy */
  .addresses { display:flex; gap:40px; margin-bottom:32px; }
  .address-block { flex:1; }
  .address-block h4 { font-size:8pt; text-transform:uppercase; letter-spacing:0.5px; color:#6b7280; margin-bottom:8px; border-bottom:1px solid #e5e7eb; padding-bottom:4px; }
  .address-block .company-name { font-weight:600; font-size:11pt; margin-bottom:4px; }
  .address-block p { line-height:1.6; color:#374151; }
  .address-block .ico { margin-top:6px; font-size:9pt; color:#6b7280; }

  /* Metadata faktury */
  .meta-table { width:100%; margin-bottom:28px; border-collapse:collapse; }
  .meta-table td { padding:5px 8px; font-size:9.5pt; }
  .meta-table .label { color:#6b7280; width:140px; }
  .meta-table .value { font-weight:500; }
  .meta-table tr:nth-child(odd) td { background:#f9fafb; }

  /* Položky */
  .items-table { width:100%; border-collapse:collapse; margin-bottom:24px; }
  .items-table th { background:#00AEC4; color:#0D1117; padding:8px 10px; text-align:left; font-size:9pt; font-weight:600; }
  .items-table th:last-child, .items-table td:last-child { text-align:right; }
  .items-table th:nth-child(2), .items-table td:nth-child(2) { text-align:center; }
  .items-table td { padding:7px 10px; border-bottom:1px solid #f3f4f6; font-size:9.5pt; }
  .items-table tr:nth-child(even) td { background:#f9fafb; }

  /* Souhrn */
  .summary { margin-left:auto; width:260px; }
  .summary-row { display:flex; justify-content:space-between; padding:5px 0; font-size:9.5pt; }
  .summary-row.total { border-top:2px solid #00AEC4; margin-top:8px; padding-top:8px; font-size:12pt; font-weight:700; color:#00AEC4; }
  .summary-row .label { color:#6b7280; }

  /* DPH tabulka */
  .vat-table { width:100%; border-collapse:collapse; margin-bottom:20px; font-size:9pt; }
  .vat-table th { background:#f3f4f6; padding:5px 8px; text-align:right; color:#6b7280; font-weight:600; }
  .vat-table th:first-child { text-align:left; }
  .vat-table td { padding:4px 8px; text-align:right; border-bottom:1px solid #f3f4f6; }
  .vat-table td:first-child { text-align:left; }

  /* Platební info */
  .payment-info { background:#e0f9fc; border:1px solid #7BE5F2; border-radius:6px; padding:12px 16px; margin-bottom:20px; }
  .payment-info h4 { color:#00AEC4; font-size:9pt; margin-bottom:6px; text-transform:uppercase; letter-spacing:0.5px; }
  .payment-info-grid { display:grid; grid-template-columns:1fr 1fr; gap:4px 20px; }
  .payment-info-grid div { font-size:9.5pt; }
  .payment-info-grid .label { color:#6b7280; font-size:8.5pt; }

  /* Patička */
  .footer { margin-top:32px; padding-top:12px; border-top:1px solid #e5e7eb; font-size:8.5pt; color:#9ca3af; text-align:center; }

  .badge-paid { display:inline-block; background:#dcfce7; color:#166534; padding:2px 8px; border-radius:4px; font-size:9pt; font-weight:600; }
  .badge-unpaid { display:inline-block; background:#fef3c7; color:#92400e; padding:2px 8px; border-radius:4px; font-size:9pt; font-weight:600; }
  .badge-overdue { display:inline-block; background:#fee2e2; color:#991b1b; padding:2px 8px; border-radius:4px; font-size:9pt; font-weight:600; }
</style>
</head>
<body>
<div class="page">

  <!-- Hlavička -->
  <div class="header">
    <div>
      <div class="company-logo"><%= issuer.name || 'one.seil.space' %></div>
      <p style="color:#6b7280;font-size:9pt;margin-top:4px;"><%= issuer.address %>, <%= issuer.zip %> <%= issuer.city %></p>
    </div>
    <div class="invoice-title">
      <h1>FAKTURA</h1>
      <div class="number"><%= invoice.number %></div>
      <div style="margin-top:8px;">
        <% if (invoice.status === 'Zaplacena') { %>
          <span class="badge-paid">ZAPLACENO</span>
        <% } else if (invoice.status === 'Po splatnosti') { %>
          <span class="badge-overdue">PO SPLATNOSTI</span>
        <% } else { %>
          <span class="badge-unpaid">K ÚHRADĚ</span>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Adresy -->
  <div class="addresses">
    <div class="address-block">
      <h4>Dodavatel</h4>
      <div class="company-name"><%= issuer.name %></div>
      <p>
        <%= issuer.address %><br>
        <%= issuer.zip %> <%= issuer.city %><br>
        <%= issuer.country || 'Česká republika' %>
      </p>
      <% if (issuer.ico) { %>
      <div class="ico">
        IČO: <strong><%= issuer.ico %></strong>
        <% if (issuer.dic) { %> &nbsp;|&nbsp; DIČ: <strong><%= issuer.dic %></strong><% } %>
      </div>
      <% } %>
    </div>

    <div class="address-block">
      <h4>Odběratel</h4>
      <div class="company-name"><%= invoice.client_name || (invoice.first_name + ' ' + invoice.last_name).trim() %></div>
      <p>
        <% if (invoice.client_address) { %><%= invoice.client_address %><br><% } %>
        <% if (invoice.client_zip || invoice.client_city) { %><%= invoice.client_zip %> <%= invoice.client_city %><br><% } %>
        <%= invoice.client_country || 'Česká republika' %>
      </p>
      <% if (invoice.client_ico) { %>
      <div class="ico">
        IČO: <strong><%= invoice.client_ico %></strong>
        <% if (invoice.client_dic) { %> &nbsp;|&nbsp; DIČ: <strong><%= invoice.client_dic %></strong><% } %>
      </div>
      <% } %>
    </div>
  </div>

  <!-- Metadata -->
  <table class="meta-table">
    <tr>
      <td class="label">Datum vystavení</td>
      <td class="value"><%= new Date(invoice.issue_date).toLocaleDateString('cs-CZ') %></td>
      <td class="label" style="padding-left:40px;">Datum splatnosti</td>
      <td class="value"><%= invoice.due_date ? new Date(invoice.due_date).toLocaleDateString('cs-CZ') : 'Ihned' %></td>
    </tr>
    <tr>
      <td class="label">Forma platby</td>
      <td class="value">Bankovní převod</td>
      <td class="label" style="padding-left:40px;">Variabilní symbol</td>
      <td class="value"><%= invoice.number.replace(/[^0-9]/g, '') || invoice.number %></td>
    </tr>
    <% if (invoice.order_number) { %>
    <tr>
      <td class="label">Číslo objednávky</td>
      <td class="value" colspan="3"><%= invoice.order_number %></td>
    </tr>
    <% } %>
  </table>

  <!-- Položky -->
  <table class="items-table">
    <thead>
      <tr>
        <th style="width:50%;">Popis</th>
        <th style="width:10%;">Množství</th>
        <th style="width:8%;">MJ</th>
        <th style="width:14%;">Cena/MJ</th>
        <th style="width:8%;">DPH %</th>
        <th style="width:10%;">Celkem</th>
      </tr>
    </thead>
    <tbody>
      <% items.forEach(item => { %>
      <tr>
        <td><%= item.name %></td>
        <td style="text-align:center;"><%= item.quantity %></td>
        <td style="text-align:center;"><%= item.unit || 'ks' %></td>
        <td style="text-align:right;"><%= Number(item.price_per_unit).toLocaleString('cs-CZ', {minimumFractionDigits:2}) %> Kč</td>
        <td style="text-align:center;"><%= item.vat_rate %> %</td>
        <td style="text-align:right;font-weight:500;"><%= Number(item.total).toLocaleString('cs-CZ', {minimumFractionDigits:2}) %> Kč</td>
      </tr>
      <% }) %>
    </tbody>
  </table>

  <!-- DPH souhrn + celkem -->
  <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:24px;">

    <!-- DPH tabulka -->
    <% if (vatSummary && vatSummary.length > 0) { %>
    <div style="width:320px;">
      <table class="vat-table">
        <thead>
          <tr><th>Sazba DPH</th><th>Základ</th><th>DPH</th><th>Celkem</th></tr>
        </thead>
        <tbody>
          <% vatSummary.forEach(vs => { %>
          <tr>
            <td><%= vs.rate %> %</td>
            <td><%= Number(vs.base).toLocaleString('cs-CZ', {minimumFractionDigits:2}) %> Kč</td>
            <td><%= Number(vs.vat).toLocaleString('cs-CZ', {minimumFractionDigits:2}) %> Kč</td>
            <td><%= Number(vs.total).toLocaleString('cs-CZ', {minimumFractionDigits:2}) %> Kč</td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>

    <!-- Celkem -->
    <div class="summary">
      <div class="summary-row">
        <span class="label">Základ daně celkem</span>
        <span><%= Number(invoice.amount).toLocaleString('cs-CZ', {minimumFractionDigits:2}) %> <%= invoice.currency || 'Kč' %></span>
      </div>
      <div class="summary-row">
        <span class="label">DPH celkem</span>
        <span><%= Number(invoice.vat_amount).toLocaleString('cs-CZ', {minimumFractionDigits:2}) %> <%= invoice.currency || 'Kč' %></span>
      </div>
      <div class="summary-row total">
        <span>K ÚHRADĚ</span>
        <span><%= Number(invoice.total_amount).toLocaleString('cs-CZ', {minimumFractionDigits:2}) %> <%= invoice.currency || 'Kč' %></span>
      </div>
    </div>
  </div>

  <!-- Platební info -->
  <div class="payment-info">
    <h4>Platební instrukce</h4>
    <div class="payment-info-grid">
      <div>
        <div class="label">Číslo účtu</div>
        <div><strong><%= issuer.bank_account || '—' %></strong></div>
      </div>
      <div>
        <div class="label">IBAN</div>
        <div><%= issuer.iban || '—' %></div>
      </div>
      <div>
        <div class="label">Banka</div>
        <div><%= issuer.bank_name || '—' %></div>
      </div>
      <div>
        <div class="label">SWIFT/BIC</div>
        <div><%= issuer.swift || '—' %></div>
      </div>
      <div>
        <div class="label">Variabilní symbol</div>
        <div><strong><%= invoice.number.replace(/[^0-9]/g, '') || invoice.number %></strong></div>
      </div>
    </div>
  </div>

  <% if (issuer.invoice_note) { %>
  <p style="font-size:9pt;color:#6b7280;margin-bottom:16px;"><%= issuer.invoice_note %></p>
  <% } %>

  <!-- Patička -->
  <div class="footer">
    <%= issuer.name %> &nbsp;|&nbsp; IČO: <%= issuer.ico %>
    <% if (issuer.dic) { %>&nbsp;|&nbsp; DIČ: <%= issuer.dic %><% } %>
    <% if (issuer.email) { %>&nbsp;|&nbsp; <%= issuer.email %><% } %>
  </div>

</div>
</body>
</html>
