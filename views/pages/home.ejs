<%
  const profit = kpi.issuedMonth - kpi.receivedMonth;
  const monthLabel = monthOptions.find(m => m.value === selectedMonth)?.label || selectedMonth;
%>

<div class="page-header">
  <div class="page-header-left">
    <h1>Dobrý den<% if (user && user.first_name) { %>, <%= user.first_name %><% } %></h1>
    <p>Přehled stavu pro <%= monthLabel %></p>
  </div>
</div>

<!-- ══ ÚČETNICTVÍ ══════════════════════════════════════════════ -->
<div class="dash-section">
  <div class="dash-section-header">
    <div class="dash-section-label">Účetnictví</div>
    <form method="get" action="/" style="margin:0;">
      <select name="month" class="form-select" style="font-size:13px;padding:6px 10px;" onchange="this.form.submit()">
        <% monthOptions.forEach(m => { %>
        <option value="<%= m.value %>" <%= m.value === selectedMonth ? 'selected' : '' %>><%= m.label %></option>
        <% }) %>
      </select>
    </form>
  </div>

  <div class="kpi-grid dash-kpi-row" style="margin-bottom:24px;">

    <a href="/ucetnictvi/vydane-faktury" class="kpi-card kpi-link">
      <div class="kpi-label">Tržby</div>
      <div class="kpi-value positive kpi-anim" data-value="<%= kpi.issuedMonth %>" data-fmt="czk" style="font-size:20px;">—</div>
      <div class="kpi-formula kpi-anim" data-value="<%= kpi.issuedCount %>" data-fmt="count" data-suffix=" vydaných faktur">—</div>
    </a>

    <a href="/ucetnictvi/prijate-faktury" class="kpi-card kpi-link">
      <div class="kpi-label">Náklady</div>
      <div class="kpi-value negative kpi-anim" data-value="<%= kpi.receivedMonth %>" data-fmt="czk" style="font-size:20px;">—</div>
      <div class="kpi-formula kpi-anim" data-value="<%= kpi.receivedCount || 0 %>" data-fmt="count" data-suffix=" přijatých faktur">—</div>
    </a>

    <a href="/ucetnictvi/uctenky" class="kpi-card kpi-link">
      <div class="kpi-label">Účtenky</div>
      <div class="kpi-value kpi-anim" data-value="<%= kpi.uctenkyMonth %>" data-fmt="czk" style="font-size:20px;">—</div>
      <div class="kpi-formula kpi-anim" data-value="<%= kpi.uctenkyCount %>" data-fmt="count" data-suffix=" dokladů">—</div>
    </a>

    <a href="/ucetnictvi/prehled" class="kpi-card kpi-link">
      <div class="kpi-label">Hrubý zisk</div>
      <div class="kpi-value <%= profit >= 0 ? 'positive' : 'negative' %> kpi-anim" data-value="<%= profit %>" data-fmt="czk" style="font-size:20px;">—</div>
      <div class="kpi-formula">Tržby − náklady</div>
    </a>

    <a href="/ucetnictvi/prehled" class="kpi-card kpi-link">
      <div class="kpi-label">Po splatnosti</div>
      <div class="kpi-value <%= kpi.overdue > 0 ? 'negative' : '' %> kpi-anim" data-value="<%= kpi.overdue %>" data-fmt="int" style="font-size:28px;">—</div>
      <div class="kpi-formula">Faktur čeká</div>
    </a>

    <a href="/ucetnictvi/objednavky" class="kpi-card kpi-link">
      <div class="kpi-label">Objednávky</div>
      <div class="kpi-value primary-color kpi-anim" data-value="<%= kpi.ordersWaiting %>" data-fmt="int" style="font-size:28px;">—</div>
      <div class="kpi-formula">K vyřízení</div>
    </a>

  </div>

  <!-- Mapa objednávek podle města -->
  <div class="dash-section-label" style="margin-bottom:10px;">Objednávky podle města — <%= monthLabel %></div>
  <div style="display:grid;grid-template-columns:minmax(220px,320px) 1fr;gap:20px;align-items:start;">
    <div class="cz-map-card" id="czMapCard">
      <div class="cz-map-toolbar">
        <button type="button" class="cz-map-btn" data-action="zoom-out" aria-label="Oddálit mapu">−</button>
        <button type="button" class="cz-map-btn" data-action="zoom-in" aria-label="Přiblížit mapu">+</button>
        <button type="button" class="cz-map-btn" data-action="fullscreen" aria-label="Zobrazit mapu na celou obrazovku">⛶</button>
      </div>
      <div class="cz-map-wrap" id="czMapWrap">
        <div class="cz-map-inner" id="czMapInner">
          <img src="/static/img/cz-mapa.svg" alt="Mapa ČR" class="cz-map-bg">
          <% mapPoints.forEach(p => { %>
          <div class="cz-map-pin" style="left:<%= p.xPct.toFixed(2) %>%;top:<%= p.yPct.toFixed(2) %>%;" title="<%= p.label %>: <%= p.n %> objednávek">
            <span class="cz-map-dot"><%= p.n %></span>
            <span class="cz-map-pin-label"><%= p.label %></span>
          </div>
          <% }) %>
          <% if (mapPoints.length === 0) { %>
          <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;color:var(--text-muted);font-size:13px;">Žádné objednávky v tomto měsíci</div>
          <% } %>
        </div>
      </div>
    </div>
    <div>
      <% if (otherCities.length > 0) { %>
      <div style="font-size:12px;color:var(--text-muted);font-weight:600;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:8px;">Ostatní obce</div>
      <div style="display:flex;flex-direction:column;gap:6px;max-height:220px;overflow-y:auto;">
        <% otherCities.forEach(c => { %>
        <div style="display:flex;justify-content:space-between;font-size:13px;">
          <span><%= c.label %></span>
          <span style="font-weight:600;color:var(--text-primary);"><%= c.n %></span>
        </div>
        <% }) %>
      </div>
      <% } %>
    </div>
  </div>
</div>

<!-- ══ MONITORING ═════════════════════════════════════════════ -->
<div class="dash-section">
  <div class="dash-section-header">
    <div class="dash-section-label">Monitoring</div>
    <a href="/monitoring" style="font-size:11px;color:var(--primary);font-weight:500;text-decoration:none;">Zobrazit detail →</a>
  </div>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;">

    <% if (vps) { %>
    <div class="kpi-grid" style="grid-template-columns:1fr 1fr 1fr;">
      <% if (vps.ram) { %>
      <div class="kpi-card">
        <div class="kpi-label">RAM</div>
        <% const ramPct = Math.round(vps.ram.used_mb / vps.ram.total_mb * 100); %>
        <div class="kpi-value kpi-anim <%= ramPct > 90 ? 'negative' : ramPct > 75 ? '' : 'positive' %>"
             data-value="<%= ramPct %>" data-fmt="int" data-suffix=" %" style="font-size:22px;">—</div>
        <div class="kpi-formula"><%= vps.ram.used_mb %> / <%= vps.ram.total_mb %> MB</div>
      </div>
      <% } %>
      <% if (vps.cpu) { %>
      <div class="kpi-card">
        <div class="kpi-label">CPU load</div>
        <% const cpuVal = vps.cpu.load_1m || 0; %>
        <div class="kpi-value kpi-anim <%= cpuVal > 2 ? 'negative' : 'positive' %>"
             data-value="<%= cpuVal %>" data-fmt="dec" style="font-size:22px;">—</div>
        <div class="kpi-formula">1min průměr</div>
      </div>
      <% } %>
      <% if (vps.disk) { %>
      <div class="kpi-card">
        <div class="kpi-label">Disk</div>
        <% const diskPct = Math.round(vps.disk.used_gb / vps.disk.total_gb * 100); %>
        <div class="kpi-value kpi-anim <%= diskPct > 85 ? 'negative' : diskPct > 70 ? '' : 'positive' %>"
             data-value="<%= diskPct %>" data-fmt="int" data-suffix=" %" style="font-size:22px;">—</div>
        <div class="kpi-formula"><%= vps.disk.used_gb %> / <%= vps.disk.total_gb %> GB</div>
      </div>
      <% } %>
    </div>
    <% } else { %>
    <div class="card" style="display:flex;align-items:center;justify-content:center;min-height:80px;">
      <span style="color:var(--text-muted);font-size:13px;">VPS collector neběží · <a href="/monitoring" style="color:var(--primary);">detail</a></span>
    </div>
    <% } %>

    <!-- Healthchecky aplikací -->
    <div class="card" id="hcCard">
      <div class="card-header" style="display:flex;justify-content:space-between;align-items:center;">
        <span>Aplikace</span>
        <span id="hcUpdated" style="font-size:11px;color:var(--text-muted);"></span>
      </div>
      <div class="card-body" id="hcBody" style="display:flex;flex-direction:column;gap:6px;padding:12px 16px;">
        <span style="color:var(--text-muted);font-size:13px;">Načítám…</span>
      </div>
    </div>

  </div>
</div>

<!-- ══ RYCHLÉ ODKAZY ══════════════════════════════════════════ -->
<div class="dash-section" style="margin-bottom:0;">
  <div class="dash-section-header">
    <div class="dash-section-label">Rychlé odkazy</div>
  </div>
  <div class="kpi-grid" style="grid-template-columns:1fr 1fr;">
    <a href="https://coolify.seil.space/" target="_blank" class="kpi-card kpi-link" style="display:flex;align-items:center;gap:14px;">
      <div style="font-size:24px;">🚀</div>
      <div>
        <div style="font-weight:600;color:var(--text-primary);">Coolify</div>
        <div style="font-size:12px;color:var(--text-muted);margin-top:2px;">Správa nasazení</div>
      </div>
    </a>
    <a href="https://platform.claude.com/cost?api_key=apikey_01SYfe4d7CUHQCoeppQewiQa" target="_blank" class="kpi-card kpi-link" style="display:flex;align-items:center;gap:14px;">
      <div style="font-size:24px;">💳</div>
      <div>
        <div style="font-weight:600;color:var(--text-primary);">Claude Console — Cost</div>
        <div style="font-size:12px;color:var(--text-muted);margin-top:2px;">Sledování nákladů API</div>
      </div>
    </a>
  </div>
</div>

<style>
.dash-section {
  border: 1px solid var(--border);
  border-radius: var(--radius-lg, 12px);
  background: var(--bg-card);
  padding: 20px;
  margin-bottom: 24px;
}
.dash-section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 12px;
  margin-bottom: 16px;
}
.dash-section-label {
  font-family: var(--font-mono);
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: var(--text-muted);
}
.kpi-link {
  text-decoration: none;
  transition: transform 0.15s, box-shadow 0.15s;
}
.kpi-link:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 16px rgba(0,0,0,0.1);
}
.kpi-anim {
  transition: opacity 0.2s;
}
@keyframes kpi-fade-in {
  from { opacity: 0; transform: translateY(6px); }
  to   { opacity: 1; transform: translateY(0); }
}
.kpi-card {
  animation: kpi-fade-in 0.35s ease both;
}
.kpi-grid .kpi-card:nth-child(1) { animation-delay: 0ms; }
.kpi-grid .kpi-card:nth-child(2) { animation-delay: 50ms; }
.kpi-grid .kpi-card:nth-child(3) { animation-delay: 100ms; }
.kpi-grid .kpi-card:nth-child(4) { animation-delay: 150ms; }
.kpi-grid .kpi-card:nth-child(5) { animation-delay: 200ms; }
.kpi-grid .kpi-card:nth-child(6) { animation-delay: 250ms; }

.cz-map-card {
  position: relative;
}
.cz-map-toolbar {
  position: absolute;
  top: 8px;
  right: 8px;
  z-index: 2;
  display: flex;
  gap: 4px;
}
.cz-map-btn {
  width: 26px;
  height: 26px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm, 6px);
  background: var(--bg-card);
  color: var(--text-secondary);
  font-size: 14px;
  line-height: 1;
  cursor: pointer;
  transition: background var(--transition-fast, 150ms ease), color var(--transition-fast, 150ms ease), border-color var(--transition-fast, 150ms ease);
}
.cz-map-btn:hover {
  background: var(--primary);
  border-color: var(--primary);
  color: #fff;
}
.cz-map-wrap {
  position: relative;
  width: 100%;
  max-width: 320px;
  aspect-ratio: 1004.4976 / 611.14276;
  background: var(--bg-page, #f8f9fa);
  border: 1px solid var(--border);
  border-radius: var(--radius-md, 8px);
  overflow: hidden;
}
.cz-map-inner {
  position: relative;
  width: 100%;
  height: 100%;
  transform-origin: center center;
  transition: transform 0.2s ease;
}
.cz-map-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: contain;
}
.cz-map-pin {
  position: absolute;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 1;
}
.cz-map-dot {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 22px;
  height: 22px;
  padding: 0 5px;
  border-radius: 11px;
  background: var(--primary);
  color: #fff;
  font-size: 11px;
  font-weight: 700;
  box-shadow: 0 1px 4px rgba(0,0,0,0.25);
  cursor: default;
}
.cz-map-pin-label {
  font-size: 9px;
  font-family: var(--font-mono);
  color: var(--text-muted);
  margin-top: 2px;
  white-space: nowrap;
  background: var(--bg-card);
  padding: 0 3px;
  border-radius: 3px;
}

/* Fullscreen mode */
.cz-map-card:fullscreen {
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-page);
  padding: 40px;
}
.cz-map-card:fullscreen .cz-map-wrap {
  width: 90vw;
  max-width: 1100px;
  height: auto;
}
.cz-map-card:fullscreen .cz-map-toolbar {
  top: 24px;
  right: 24px;
}
.cz-map-card:fullscreen .cz-map-btn,
.cz-map-card:-webkit-full-screen .cz-map-btn {
  width: 34px;
  height: 34px;
  font-size: 18px;
}
.cz-map-card:-webkit-full-screen {
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-page);
  padding: 40px;
}
.cz-map-card:-webkit-full-screen .cz-map-wrap {
  width: 90vw;
  max-width: 1100px;
  height: auto;
}
.cz-map-card:-webkit-full-screen .cz-map-toolbar {
  top: 24px;
  right: 24px;
}
</style>

<script>
(function () {
  // Animace čísel
  function animateCounter(el) {
    const target   = parseFloat(el.dataset.value) || 0;
    const fmt      = el.dataset.fmt || 'int';
    const prefix   = el.dataset.prefix || '';
    const suffix   = el.dataset.suffix || '';
    const duration = 700;
    const start    = performance.now();

    function format(v) {
      switch (fmt) {
        case 'czk':   return prefix + Number(v).toLocaleString('cs-CZ',{minimumFractionDigits:2}) + ' Kč' + suffix;
        case 'int':   return prefix + Math.round(v).toLocaleString('cs-CZ') + suffix;
        case 'dec':   return prefix + v.toFixed(2) + suffix;
        case 'count': return prefix + Math.round(v).toLocaleString('cs-CZ') + suffix;
        default:      return prefix + v + suffix;
      }
    }

    function step(now) {
      const elapsed = now - start;
      const progress = Math.min(elapsed / duration, 1);
      // Ease out cubic
      const eased = 1 - Math.pow(1 - progress, 3);
      el.textContent = format(target * eased);
      if (progress < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }

  // Spustit animaci pro všechny prvky při načtení
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        animateCounter(entry.target);
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.kpi-anim').forEach(el => observer.observe(el));

  // Healthchecky
  fetch('/api/healthchecks/status').then(r=>r.json()).then(checks => {
    const body = document.getElementById('hcBody');
    const upd  = document.getElementById('hcUpdated');
    if (!checks.length) {
      body.innerHTML = '<span style="color:var(--text-muted);font-size:13px;">Žádné sledované aplikace · <a href="/nastaveni/healthchecky" style="color:var(--primary);">Přidat</a></span>';
      return;
    }
    body.innerHTML = checks.map(c => {
      const ok  = c.ok;
      const dot = ok === null ? '⚪' : ok ? '🟢' : '🔴';
      const lat = c.latency_ms ? ` <span style="color:var(--text-muted);font-size:11px;">${c.latency_ms}ms</span>` : '';
      const err = !ok && c.error ? `<span style="color:var(--danger);font-size:11px;"> — ${c.error}</span>` : '';
      return `<div style="display:flex;align-items:center;gap:8px;">${dot} <span style="font-weight:500;font-size:13px;">${c.name}</span>${lat}${err}</div>`;
    }).join('');
    const lastCheck = checks.find(c=>c.checked_at)?.checked_at;
    if (lastCheck) upd.textContent = 'aktualizováno ' + new Date(lastCheck).toLocaleTimeString('cs-CZ',{hour:'2-digit',minute:'2-digit'});
  }).catch(() => {
    document.getElementById('hcBody').innerHTML = '<span style="color:var(--text-muted);font-size:13px;">Nedostupné</span>';
  });

  // Mapa — zoom a celá obrazovka
  const mapCard  = document.getElementById('czMapCard');
  const mapInner = document.getElementById('czMapInner');
  if (mapCard && mapInner) {
    const MIN_ZOOM = 1, MAX_ZOOM = 2.5, STEP = 0.25;
    let zoom = 1;

    function applyZoom() {
      mapInner.style.transform = 'scale(' + zoom + ')';
    }

    function isFullscreen() {
      return document.fullscreenElement === mapCard || document.webkitFullscreenElement === mapCard;
    }

    mapCard.querySelectorAll('[data-action]').forEach(btn => {
      btn.addEventListener('click', () => {
        const action = btn.dataset.action;
        if (action === 'zoom-in') {
          zoom = Math.min(MAX_ZOOM, +(zoom + STEP).toFixed(2));
          applyZoom();
        } else if (action === 'zoom-out') {
          zoom = Math.max(MIN_ZOOM, +(zoom - STEP).toFixed(2));
          applyZoom();
        } else if (action === 'fullscreen') {
          if (!isFullscreen()) {
            (mapCard.requestFullscreen || mapCard.webkitRequestFullscreen)?.call(mapCard);
          } else {
            (document.exitFullscreen || document.webkitExitFullscreen)?.call(document);
          }
        }
      });
    });

    ['fullscreenchange', 'webkitfullscreenchange'].forEach(evt => {
      document.addEventListener(evt, () => {
        zoom = 1;
        applyZoom();
      });
    });
  }
})();
</script>
