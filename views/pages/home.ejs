<%
  const fmt = (n) => Number(n||0).toLocaleString('cs-CZ', {minimumFractionDigits:0});
  const fmtCzk = (n) => Number(n||0).toLocaleString('cs-CZ', {minimumFractionDigits:2}) + ' Kč';
  const profit = kpi.issuedMonth - kpi.receivedMonth;
%>

<div class="page-header">
  <div class="page-header-left">
    <h1>Dobrý den<% if (user && user.first_name) { %>, <%= user.first_name %><% } %></h1>
    <p>Přehled stavu pro <%= new Date().toLocaleDateString('cs-CZ', {month:'long', year:'numeric'}) %></p>
  </div>
</div>

<!-- ══ ÚČETNICTVÍ ═══════════════════════════════════════════ -->
<div style="margin-bottom:6px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.8px;color:var(--text-muted);">Účetnictví — tento měsíc</div>
<div class="kpi-grid" style="margin-bottom:28px;">
  <a href="/ucetnictvi/vydane-faktury" class="kpi-card" style="text-decoration:none;">
    <div class="kpi-label">Tržby</div>
    <div class="kpi-value positive" style="font-size:20px;"><%= fmtCzk(kpi.issuedMonth) %></div>
    <div class="kpi-formula"><%= kpi.issuedCount %> vydaných faktur</div>
  </a>
  <a href="/ucetnictvi/prijate-faktury" class="kpi-card" style="text-decoration:none;">
    <div class="kpi-label">Náklady</div>
    <div class="kpi-value negative" style="font-size:20px;"><%= fmtCzk(kpi.receivedMonth) %></div>
    <div class="kpi-formula"><%= kpi.receivedCount || 0 %> přijatých faktur</div>
  </a>
  <a href="/ucetnictvi/prehled" class="kpi-card" style="text-decoration:none;">
    <div class="kpi-label">Hrubý zisk</div>
    <div class="kpi-value <%= profit >= 0 ? 'positive' : 'negative' %>" style="font-size:20px;"><%= fmtCzk(profit) %></div>
    <div class="kpi-formula">Tržby − náklady</div>
  </a>
  <a href="/ucetnictvi/prehled" class="kpi-card" style="text-decoration:none;">
    <div class="kpi-label">Faktury po splatnosti</div>
    <div class="kpi-value <%= kpi.overdue > 0 ? 'negative' : '' %>" style="font-size:28px;"><%= kpi.overdue %></div>
    <div class="kpi-formula">Vyžadují pozornost</div>
  </a>
  <a href="/ucetnictvi/objednavky" class="kpi-card" style="text-decoration:none;">
    <div class="kpi-label">Objednávky čekají</div>
    <div class="kpi-value primary-color" style="font-size:28px;"><%= kpi.ordersWaiting %></div>
    <div class="kpi-formula">K vyřízení</div>
  </a>
</div>

<!-- ══ CRM + LIDÉ ════════════════════════════════════════════ -->
<div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-bottom:28px;">

  <div>
    <div style="margin-bottom:6px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.8px;color:var(--text-muted);">CRM</div>
    <div class="kpi-grid" style="grid-template-columns:1fr 1fr 1fr;">
      <a href="/crm/firmy" class="kpi-card" style="text-decoration:none;">
        <div class="kpi-label">Firmy</div>
        <div class="kpi-value" style="font-size:28px;"><%= kpi.firmy %></div>
      </a>
      <a href="/crm/kontakty" class="kpi-card" style="text-decoration:none;">
        <div class="kpi-label">Kontakty</div>
        <div class="kpi-value" style="font-size:28px;"><%= kpi.kontakty %></div>
      </a>
      <a href="/crm/kontakty" class="kpi-card" style="text-decoration:none;">
        <div class="kpi-label">Nové (30 dní)</div>
        <div class="kpi-value positive" style="font-size:28px;">+<%= kpi.crmNew %></div>
      </a>
    </div>
  </div>

  <div>
    <div style="margin-bottom:6px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.8px;color:var(--text-muted);">Lidé &amp; Kultura</div>
    <a href="/lide/tym" class="kpi-card" style="text-decoration:none;display:flex;align-items:center;gap:20px;padding:20px;">
      <div style="font-size:40px;font-weight:700;color:var(--primary);line-height:1;"><%= kpi.team %></div>
      <div>
        <div style="font-weight:600;color:var(--text-primary);">Členů týmu</div>
        <div style="font-size:13px;color:var(--text-muted);margin-top:2px;">Aktivní uživatelé</div>
      </div>
    </a>
  </div>

</div>

<!-- ══ VPS + HEALTHCHECKY ═════════════════════════════════════ -->
<div style="margin-bottom:6px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.8px;color:var(--text-muted);">
  Monitoring
  <a href="/monitoring" style="margin-left:8px;font-size:11px;color:var(--primary);font-weight:500;text-decoration:none;">Zobrazit detail →</a>
</div>
<div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-bottom:8px;">

  <!-- VPS metriky -->
  <% if (vps) { %>
  <div class="kpi-grid" style="grid-template-columns:1fr 1fr 1fr;">
    <% if (vps.ram) { %>
    <div class="kpi-card">
      <div class="kpi-label">RAM</div>
      <% const ramPct = Math.round(vps.ram.used_mb / vps.ram.total_mb * 100); %>
      <div class="kpi-value <%= ramPct > 90 ? 'negative' : ramPct > 75 ? '' : 'positive' %>" style="font-size:22px;"><%= ramPct %> %</div>
      <div class="kpi-formula"><%= vps.ram.used_mb %> / <%= vps.ram.total_mb %> MB</div>
    </div>
    <% } %>
    <% if (vps.cpu) { %>
    <div class="kpi-card">
      <div class="kpi-label">CPU load</div>
      <% const cpuVal = vps.cpu.load_1m || 0; %>
      <div class="kpi-value <%= cpuVal > 2 ? 'negative' : 'positive' %>" style="font-size:22px;"><%= cpuVal %></div>
      <div class="kpi-formula">1min průměr</div>
    </div>
    <% } %>
    <% if (vps.disk) { %>
    <div class="kpi-card">
      <div class="kpi-label">Disk</div>
      <% const diskPct = Math.round(vps.disk.used_gb / vps.disk.total_gb * 100); %>
      <div class="kpi-value <%= diskPct > 85 ? 'negative' : diskPct > 70 ? '' : 'positive' %>" style="font-size:22px;"><%= diskPct %> %</div>
      <div class="kpi-formula"><%= vps.disk.used_gb %> / <%= vps.disk.total_gb %> GB</div>
    </div>
    <% } %>
  </div>
  <% } else { %>
  <div class="card" style="display:flex;align-items:center;justify-content:center;min-height:80px;">
    <span style="color:var(--text-muted);font-size:13px;">VPS collector neběží · <a href="/monitoring" style="color:var(--primary);">detail</a></span>
  </div>
  <% } %>

  <!-- Healthchecky aplikací -->
  <div class="card" id="hcCard">
    <div class="card-header" style="display:flex;justify-content:space-between;align-items:center;">
      <span>Aplikace</span>
      <span id="hcUpdated" style="font-size:11px;color:var(--text-muted);"></span>
    </div>
    <div class="card-body" id="hcBody" style="display:flex;flex-direction:column;gap:6px;padding:12px 16px;">
      <span style="color:var(--text-muted);font-size:13px;">Načítám…</span>
    </div>
  </div>

</div>

<script>
fetch('/api/healthchecks/status').then(r=>r.json()).then(checks => {
  const body = document.getElementById('hcBody');
  const upd  = document.getElementById('hcUpdated');
  if (!checks.length) {
    body.innerHTML = '<span style="color:var(--text-muted);font-size:13px;">Žádné sledované aplikace · <a href="/nastaveni/healthchecky" style="color:var(--primary);">Přidat</a></span>';
    return;
  }
  body.innerHTML = checks.map(c => {
    const ok  = c.ok;
    const dot = ok === null ? '⚪' : ok ? '🟢' : '🔴';
    const lat = c.latency_ms ? ` <span style="color:var(--text-muted);font-size:11px;">${c.latency_ms}ms</span>` : '';
    const err = !ok && c.error ? `<span style="color:var(--danger);font-size:11px;"> — ${c.error}</span>` : '';
    return `<div style="display:flex;align-items:center;gap:8px;">${dot} <span style="font-weight:500;font-size:13px;">${c.name}</span>${lat}${err}</div>`;
  }).join('');
  const lastCheck = checks.find(c=>c.checked_at)?.checked_at;
  if (lastCheck) upd.textContent = 'aktualizováno ' + new Date(lastCheck).toLocaleTimeString('cs-CZ',{hour:'2-digit',minute:'2-digit'});
}).catch(() => {
  document.getElementById('hcBody').innerHTML = '<span style="color:var(--text-muted);font-size:13px;">Nedostupné</span>';
});
</script>
