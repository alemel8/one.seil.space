<%
  const statusStyle = s => ({
    'Přijata':       'background:#dbeafe;color:#1e40af',
    'Vyřízena':      'background:#dcfce7;color:#166534',
    'Stornována':    'background:#fee2e2;color:#991b1b',
  }[s] || 'background:#f1f5f9;color:#475569');
%>

<div class="page-header">
  <div class="page-header-left">
    <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
      <a href="/crm/kontakty" style="color:var(--text-muted);text-decoration:none;font-size:13px;">← Kontakty</a>
      <span style="color:var(--border);">/</span>
      <h1 style="margin:0;"><%= contact.first_name %> <%= contact.last_name %></h1>
      <% if (contact.is_registered) { %>
        <span class="badge" style="background:#dcfce7;color:#166534;">Registrovaný</span>
      <% } else { %>
        <span class="badge" style="background:#f1f5f9;color:#475569;">Host</span>
      <% } %>
    </div>
    <% if (contact.company_name) { %>
      <p style="margin-top:4px;font-size:13px;color:var(--text-muted);">
        <a href="/crm/firmy/<%= contact.company_id %>" style="color:var(--primary)"><%= contact.company_name %></a>
      </p>
    <% } %>
  </div>
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;align-items:start;">

  <!-- Základní info -->
  <div class="card">
    <div class="card-body">
      <h2 style="font-size:13px;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:.05em;margin:0 0 16px;">Informace</h2>
      <dl style="display:grid;grid-template-columns:120px 1fr;gap:8px 16px;font-size:13px;margin:0;">
        <% if (contact.title) { %>
        <dt style="color:var(--text-muted);">Pozice</dt>
        <dd style="margin:0;"><%= contact.title %></dd>
        <% } %>
        <% if (contact.company_name) { %>
        <dt style="color:var(--text-muted);">Firma</dt>
        <dd style="margin:0;"><a href="/crm/firmy/<%= contact.company_id %>" style="color:var(--primary)"><%= contact.company_name %></a></dd>
        <% } %>
        <% if (contact.email) { %>
        <dt style="color:var(--text-muted);">E-mail</dt>
        <dd style="margin:0;"><a href="mailto:<%= contact.email %>" style="color:var(--primary)"><%= contact.email %></a></dd>
        <% } %>
        <% if (contact.phone) { %>
        <dt style="color:var(--text-muted);">Telefon</dt>
        <dd style="margin:0;"><%= contact.phone %></dd>
        <% } %>
        <dt style="color:var(--text-muted);">Přidán</dt>
        <dd style="margin:0;"><%= new Date(contact.created_at).toLocaleDateString('cs-CZ') %></dd>
        <dt style="color:var(--text-muted);">Stav</dt>
        <dd style="margin:0;">
          <% if (contact.is_registered) { %>
            <span class="badge" style="background:#dcfce7;color:#166534;">Registrovaný zákazník</span>
          <% } else { %>
            <span class="badge" style="background:#f1f5f9;color:#475569;">Host (bez registrace)</span>
          <% } %>
        </dd>
      </dl>
      <% if (contact.notes) { %>
      <div style="margin-top:16px;padding-top:16px;border-top:1px solid var(--border);">
        <div style="font-size:12px;color:var(--text-muted);margin-bottom:6px;">Poznámky</div>
        <p style="font-size:13px;color:var(--text-primary);line-height:1.5;"><%= contact.notes %></p>
      </div>
      <% } %>
    </div>
  </div>

  <!-- Objednávky -->
  <div class="card">
    <div class="card-body">
      <h2 style="font-size:13px;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:.05em;margin:0 0 16px;">Objednávky (<%= orders.length %>)</h2>
      <% if (orders.length > 0) { %>
        <% orders.forEach(o => { %>
        <a href="/ucetnictvi/objednavky/<%= o.id %>" style="display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid var(--border);text-decoration:none;color:inherit;">
          <div>
            <div style="font-size:13px;font-weight:500;">#<%= o.order_number %></div>
            <div style="font-size:11px;color:var(--text-muted);"><%= new Date(o.created_at).toLocaleDateString('cs-CZ') %></div>
          </div>
          <div style="display:flex;align-items:center;gap:10px;">
            <span style="font-size:13px;font-variant-numeric:tabular-nums;"><%= o.total_price.toLocaleString('cs-CZ') %> Kč</span>
            <span class="badge" style="<%= statusStyle(o.status) %>"><%= o.status %></span>
          </div>
        </a>
        <% }); %>
      <% } else { %>
        <p style="color:var(--text-muted);font-size:13px;">Žádné objednávky</p>
      <% } %>
    </div>
  </div>

</div>
