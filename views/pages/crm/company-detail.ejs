<script>
document.querySelectorAll('[data-modal-open]').forEach(function(b) {
  b.addEventListener('click', function() {
    var el = document.getElementById(b.dataset.modalOpen);
    if (el) el.classList.add('open');
  });
});

async function syncAres() {
  var ico = '<%= company.ico %>';
  if (!ico) return;
  var btn = event.target.closest('button');
  btn.disabled = true; btn.textContent = 'Načítám…';
  try {
    var res  = await fetch('/api/ares/' + ico);
    var data = await res.json();
    if (!res.ok) { alert('ARES: ' + (data.error || 'chyba')); btn.disabled=false; btn.textContent='Sync ARES'; return; }
    var form = document.getElementById('aresForm');
    var set  = function(n, v) { var i=document.createElement('input'); i.type='hidden'; i.name=n; i.value=v||''; form.appendChild(i); };
    set('name',              data.name);
    set('ico',               data.ico);
    set('dic',               data.dic);
    set('address',           data.address);
    set('city',              data.city);
    set('zip',               data.zip);
    set('country',           data.country);
    set('legal_form',        data.legal_form);
    set('founded_date',      data.founded_date || '');
    set('registration_info', data.registration_info || '');
    set('company_status',    data.company_status || '');
    set('raw',               JSON.stringify(data.raw));
    form.submit();
  } catch(e) {
    alert('ARES nedostupný: ' + e.message);
    btn.disabled=false; btn.textContent='Sync ARES';
  }
}
</script>
