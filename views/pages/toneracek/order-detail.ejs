<%
  const statusStyle = {
    'Přijata':        'background:#dbeafe;color:#1e40af',
    'Ve zpracování':  'background:#fef3c7;color:#92400e',
    'Vyřízena':       'background:#dcfce7;color:#166534',
    'Stornována':     'background:#fee2e2;color:#991b1b',
  }[order.status] || 'background:#f1f5f9;color:#475569';

  const shippingDiffers = order.shipping_address && order.shipping_address !== order.address;
%>

<div class="page-header">
  <div class="page-header-left">
    <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
      <a href="/toneracek/objednavky" style="color:var(--text-muted);text-decoration:none;font-size:13px;">← Objednávky</a>
      <span style="color:var(--border);">/</span>
      <h1 style="margin:0;">Objednávka #<%= order.order_number %></h1>
      <span class="badge" style="<%= statusStyle %>"><%= order.status %></span>
    </div>
    <p style="margin-top:4px;font-size:13px;color:var(--text-muted);">
      <%= new Date(order.created_at).toLocaleString('cs-CZ') %>
      <% if (order.invoice_number) { %>&nbsp;·&nbsp;Faktura <%= order.invoice_number %><% } %>
    </p>
  </div>
</div>

<div style="display:grid;grid-template-columns:1fr 300px;gap:20px;align-items:start;">

  <!-- ── Levý sloupec ───────────────────────────────────────── -->
  <div style="display:flex;flex-direction:column;gap:16px;">

    <!-- Položky -->
    <div class="card">
      <div class="card-body">
        <h2 style="font-size:13px;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:.05em;margin:0 0 16px;">Položky objednávky</h2>
        <table style="width:100%;border-collapse:collapse;font-size:13px;">
          <thead>
            <tr style="border-bottom:2px solid var(--border);">
              <th style="text-align:left;padding:0 0 8px;font-weight:600;color:var(--text-muted);">Název</th>
              <th style="text-align:center;padding:0 0 8px;font-weight:600;color:var(--text-muted);width:50px;">Ks</th>
              <th style="text-align:right;padding:0 0 8px;font-weight:600;color:var(--text-muted);width:90px;">Cena/ks</th>
              <th style="text-align:right;padding:0 0 8px;font-weight:600;color:var(--text-muted);width:100px;">Celkem</th>
            </tr>
          </thead>
          <tbody>
            <% items.forEach(item => { %>
            <tr style="border-bottom:1px solid var(--border);">
              <td style="padding:10px 0;">
                <%= item.name %>
                <% if (item.sku) { %><br><span style="font-size:11px;color:var(--text-muted);font-family:monospace;">SKU: <%= item.sku %></span><% } %>
              </td>
              <td style="text-align:center;padding:10px 0;"><%= item.quantity %></td>
              <td style="text-align:right;padding:10px 0;font-variant-numeric:tabular-nums;">
                <% if (item.price > 0) { %><%= item.price.toLocaleString('cs-CZ') %> Kč<% } else { %>—<% } %>
              </td>
              <td style="text-align:right;padding:10px 0;font-weight:500;font-variant-numeric:tabular-nums;">
                <% if (item.price > 0) { %><%= (item.price * item.quantity).toLocaleString('cs-CZ') %> Kč<% } else { %>—<% } %>
              </td>
            </tr>
            <% }); %>
            <tr>
              <td colspan="3" style="text-align:right;padding:12px 0 0;font-weight:600;color:var(--text-muted);">Celková částka</td>
              <td style="text-align:right;padding:12px 0 0;font-weight:700;font-size:15px;font-variant-numeric:tabular-nums;"><%= order.total_price.toLocaleString('cs-CZ') %> Kč</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Zákazník -->
    <div class="card">
      <div class="card-body">
        <h2 style="font-size:13px;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:.05em;margin:0 0 16px;">Zákazník</h2>
        <dl style="display:grid;grid-template-columns:140px 1fr;gap:8px 16px;font-size:13px;margin:0;">
          <dt style="color:var(--text-muted);">Jméno</dt>
          <dd style="margin:0;font-weight:500;"><%= order.first_name %> <%= order.last_name %></dd>

          <% if (order.company) { %>
          <dt style="color:var(--text-muted);">Firma</dt>
          <dd style="margin:0;"><%= order.company %></dd>
          <% } %>

          <% if (order.ic) { %>
          <dt style="color:var(--text-muted);">IČO</dt>
          <dd style="margin:0;"><%= order.ic %><%= order.dic ? ' / DIČ ' + order.dic : '' %></dd>
          <% } %>

          <% if (order.email) { %>
          <dt style="color:var(--text-muted);">E-mail</dt>
          <dd style="margin:0;"><a href="mailto:<%= order.email %>" style="color:var(--primary);"><%= order.email %></a></dd>
          <% } %>

          <dt style="color:var(--text-muted);">Telefon</dt>
          <dd style="margin:0;"><%= order.phone || '—' %></dd>

          <dt style="color:var(--text-muted);">Adresa</dt>
          <dd style="margin:0;"><%= order.address %>, <%= order.zip %> <%= order.city %></dd>
        </dl>
      </div>
    </div>

    <!-- Doručení -->
    <div class="card">
      <div class="card-body">
        <h2 style="font-size:13px;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:.05em;margin:0 0 16px;">Doručení</h2>
        <dl style="display:grid;grid-template-columns:140px 1fr;gap:8px 16px;font-size:13px;margin:0;">
          <dt style="color:var(--text-muted);">Způsob</dt>
          <dd style="margin:0;"><%= order.shipping_method %></dd>

          <% if (order.pickup_point_name) { %>
          <dt style="color:var(--text-muted);">Výdejní místo</dt>
          <dd style="margin:0;font-weight:500;"><%= order.pickup_point_name %>
            <% if (order.pickup_point_id) { %><br><span style="font-size:11px;color:var(--text-muted);font-family:monospace;">ID: <%= order.pickup_point_id %></span><% } %>
          </dd>
          <% } %>

          <% if (shippingDiffers) { %>
          <dt style="color:var(--text-muted);">Doručovací adresa</dt>
          <dd style="margin:0;"><%= order.shipping_first_name %> <%= order.shipping_last_name %><br><%= order.shipping_address %>, <%= order.shipping_zip %> <%= order.shipping_city %></dd>
          <% } %>

          <% if (order.tracking_number) { %>
          <dt style="color:var(--text-muted);">Číslo zásilky</dt>
          <dd style="margin:0;display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
            <strong style="font-family:monospace;"><%= order.tracking_number %></strong>
            <% if (order.label_url) { %>
              <a href="<%= order.label_url %>" target="_blank" class="btn btn-outline btn-sm">Štítek PDF</a>
            <% } %>
          </dd>
          <% } %>
        </dl>
      </div>
    </div>

    <!-- Poznámka -->
    <div class="card">
      <div class="card-body">
        <h2 style="font-size:13px;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:.05em;margin:0 0 14px;">Interní poznámka</h2>
        <form method="post" action="/toneracek/objednavky/<%= order.id %>/poznamka">
          <textarea name="notes" class="form-control" rows="3" placeholder="Poznámka pro interní potřebu…" style="margin-bottom:10px;font-size:13px;"><%= order.notes || '' %></textarea>
          <button type="submit" class="btn btn-outline btn-sm">Uložit poznámku</button>
        </form>
      </div>
    </div>

  </div>

  <!-- ── Pravý sloupec ──────────────────────────────────────── -->
  <div style="display:flex;flex-direction:column;gap:16px;">

    <!-- Platba & celkem -->
    <div class="card">
      <div class="card-body">
        <h2 style="font-size:13px;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:.05em;margin:0 0 16px;">Souhrn</h2>
        <dl style="display:flex;flex-direction:column;gap:8px;font-size:13px;margin:0;">
          <div style="display:flex;justify-content:space-between;">
            <dt style="color:var(--text-muted);">Platba</dt>
            <dd style="margin:0;"><%= order.payment_method %></dd>
          </div>
          <div style="display:flex;justify-content:space-between;">
            <dt style="color:var(--text-muted);">Doprava</dt>
            <dd style="margin:0;"><%= order.shipping_method %></dd>
          </div>
          <div style="border-top:1px solid var(--border);padding-top:10px;display:flex;justify-content:space-between;font-weight:700;font-size:15px;">
            <dt>Celkem</dt>
            <dd style="margin:0;"><%= order.total_price.toLocaleString('cs-CZ') %> Kč</dd>
          </div>
        </dl>
      </div>
    </div>

    <!-- Změna stavu -->
    <div class="card">
      <div class="card-body">
        <h2 style="font-size:13px;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:.05em;margin:0 0 16px;">Stav objednávky</h2>
        <form method="post" action="/toneracek/objednavky/<%= order.id %>/stav">
          <div style="margin-bottom:12px;">
            <label class="form-label" style="font-size:12px;">Nový stav</label>
            <select name="status" class="form-select">
              <% ORDER_STATUSES.forEach(s => { %>
                <option value="<%= s %>" <%= order.status === s ? 'selected' : '' %>><%= s %></option>
              <% }); %>
            </select>
          </div>
          <label style="display:flex;align-items:center;gap:8px;font-size:13px;cursor:pointer;margin-bottom:14px;">
            <input type="checkbox" name="send_email" value="on" checked style="width:15px;height:15px;">
            Odeslat email zákazníkovi
          </label>
          <button type="submit" class="btn btn-primary" style="width:100%;">Uložit stav</button>
        </form>
      </div>
    </div>

    <!-- Meta -->
    <div class="card">
      <div class="card-body">
        <h2 style="font-size:13px;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:.05em;margin:0 0 14px;">Informace</h2>
        <dl style="display:flex;flex-direction:column;gap:8px;font-size:12px;margin:0;color:var(--text-muted);">
          <% if (order.invoice_number) { %>
          <div style="display:flex;justify-content:space-between;">
            <dt>Faktura</dt>
            <dd style="margin:0;color:var(--text-primary);font-weight:500;"><%= order.invoice_number %></dd>
          </div>
          <% } %>
          <div style="display:flex;justify-content:space-between;">
            <dt>Vytvořena</dt>
            <dd style="margin:0;"><%= new Date(order.created_at).toLocaleString('cs-CZ') %></dd>
          </div>
          <% if (order.modified_at && order.modified_at !== order.created_at) { %>
          <div style="display:flex;justify-content:space-between;">
            <dt>Upravena</dt>
            <dd style="margin:0;"><%= new Date(order.modified_at).toLocaleString('cs-CZ') %></dd>
          </div>
          <% } %>
          <% if (order.ip_address) { %>
          <div style="display:flex;justify-content:space-between;">
            <dt>IP adresa</dt>
            <dd style="margin:0;font-family:monospace;font-size:11px;"><%= order.ip_address %></dd>
          </div>
          <% } %>
        </dl>
      </div>
    </div>

  </div>
</div>
