<div class="page-header">
  <div class="page-header-left">
    <h1>Můj profil</h1>
    <p><%= user.email %></p>
  </div>
</div>

<% if (saved) { %>
<div style="background:var(--success-bg);color:#166534;border:1px solid #bbf7d0;border-radius:var(--radius-md);padding:12px 16px;margin-bottom:20px;font-weight:500;">
  ✅ Změny uloženy
</div>
<% } %>
<% if (error === 'mismatch') { %>
<div style="background:var(--danger-bg);color:var(--danger);border:1px solid #fca5a5;border-radius:var(--radius-md);padding:12px 16px;margin-bottom:20px;font-weight:500;">
  ⚠️ Nová hesla se neshodují
</div>
<% } else if (error === 'wrongpwd') { %>
<div style="background:var(--danger-bg);color:var(--danger);border:1px solid #fca5a5;border-radius:var(--radius-md);padding:12px 16px;margin-bottom:20px;font-weight:500;">
  ⚠️ Nesprávné stávající heslo
</div>
<% } %>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;max-width:900px;">

  <!-- Profilová fotka -->
  <div class="card" style="grid-column:1/-1;">
    <div class="card-header">Profilová fotka</div>
    <div class="card-body" style="display:flex;align-items:center;gap:24px;flex-wrap:wrap;">
      <!-- Avatar preview -->
      <div id="avatarPreview" style="width:96px;height:96px;border-radius:50%;overflow:hidden;border:3px solid var(--border);flex-shrink:0;background:var(--primary);display:flex;align-items:center;justify-content:center;font-size:32px;font-weight:700;color:#fff;">
        <% if (user.photo) { %>
          <img src="/media/<%= user.photo %>" alt="Profilová fotka" id="avatarImg" style="width:100%;height:100%;object-fit:cover;">
        <% } else { %>
          <span id="avatarInitials"><%= (user.first_name||'').charAt(0).toUpperCase() %><%= (user.last_name||'').charAt(0).toUpperCase() || (user.email||'').charAt(0).toUpperCase() %></span>
        <% } %>
      </div>
      <div style="display:flex;flex-direction:column;gap:10px;">
        <form method="post" action="/profil/foto" enctype="multipart/form-data" id="fotoForm">
          <label style="cursor:pointer;">
            <input type="file" name="file" id="fotoInput" accept="image/*" style="display:none;" onchange="previewFoto(this)">
            <span class="btn btn-outline btn-sm">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:6px;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
              Vybrat fotografii
            </span>
          </label>
          <button type="submit" id="fotoSaveBtn" class="btn btn-primary btn-sm" style="display:none;">Uložit fotku</button>
        </form>
        <% if (user.photo) { %>
        <form method="post" action="/profil/foto/smazat" onsubmit="return confirm('Smazat profilovou fotku?')">
          <button type="submit" class="btn btn-ghost btn-sm" style="color:var(--danger);">Smazat fotku</button>
        </form>
        <% } %>
        <p style="font-size:12px;color:var(--text-muted);margin:0;">JPG, PNG nebo WEBP, max 5 MB</p>
      </div>
    </div>
  </div>

  <!-- Osobní údaje -->
  <div class="card">
    <div class="card-header">Osobní údaje</div>
    <form method="post" action="/profil">
      <div class="card-body" style="display:flex;flex-direction:column;gap:14px;">
        <div class="form-group">
          <label class="form-label">Jméno</label>
          <input type="text" name="first_name" class="form-control" value="<%= user.first_name || '' %>">
        </div>
        <div class="form-group">
          <label class="form-label">Příjmení</label>
          <input type="text" name="last_name" class="form-control" value="<%= user.last_name || '' %>">
        </div>
        <div class="form-group">
          <label class="form-label">E-mail</label>
          <input type="email" class="form-control" value="<%= user.email %>" disabled style="opacity:0.6;">
          <small style="color:var(--text-muted);font-size:12px;">E-mail nelze změnit</small>
        </div>
        <div class="form-group">
          <label class="form-label">Role</label>
          <input type="text" class="form-control" value="<%= user.is_admin ? 'Správce' : 'Uživatel' %>" disabled style="opacity:0.6;">
        </div>
      </div>
      <div class="modal-footer" style="border-top:1px solid var(--border);padding:14px 20px;">
        <button type="submit" class="btn btn-primary">Uložit</button>
      </div>
    </form>
  </div>

  <!-- Změna hesla -->
  <div class="card">
    <div class="card-header">Změna hesla</div>
    <form method="post" action="/profil">
      <div class="card-body" style="display:flex;flex-direction:column;gap:14px;">
        <div class="form-group">
          <label class="form-label">Stávající heslo</label>
          <input type="password" name="current_password" class="form-control" autocomplete="current-password">
        </div>
        <div class="form-group">
          <label class="form-label">Nové heslo</label>
          <input type="password" name="new_password" class="form-control" autocomplete="new-password">
        </div>
        <div class="form-group">
          <label class="form-label">Nové heslo znovu</label>
          <input type="password" name="new_password_confirm" class="form-control" autocomplete="new-password">
        </div>
      </div>
      <div class="modal-footer" style="border-top:1px solid var(--border);padding:14px 20px;">
        <button type="submit" class="btn btn-outline">Změnit heslo</button>
      </div>
    </form>
  </div>

</div>

</div>

<script>
function previewFoto(input) {
  if (!input.files[0]) return;
  const reader = new FileReader();
  reader.onload = e => {
    const preview = document.getElementById('avatarPreview');
    const initials = document.getElementById('avatarInitials');
    let img = document.getElementById('avatarImg');
    if (!img) {
      img = document.createElement('img');
      img.id = 'avatarImg';
      img.style.cssText = 'width:100%;height:100%;object-fit:cover;';
      preview.innerHTML = '';
      preview.appendChild(img);
    }
    img.src = e.target.result;
    document.getElementById('fotoSaveBtn').style.display = '';
  };
  reader.readAsDataURL(input.files[0]);
}

</script>
