<div class="page-header">
  <div class="page-header-left">
    <h1>Vydané faktury</h1>
    <p><%= total || 0 %> faktur v systému</p>
  </div>
  <button class="btn btn-primary" data-modal-open="modalCreateIssuedInvoice">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    Nová faktura
  </button>
</div>

<div class="table-wrapper">
  <table class="data-table">
    <thead>
      <tr>
        <th>Číslo</th>
        <th>Odběratel</th>
        <th>Částka</th>
        <th>Stav</th>
        <th>Splatnost</th>
        <th>Datum</th>
      </tr>
    </thead>
    <tbody>
      <% if (invoices && invoices.length > 0) { %>
        <% invoices.forEach(inv => { %>
        <tr>
          <td style="font-weight:500;font-family:var(--font-mono);letter-spacing:0.3px;"><%= inv.number %></td>
          <td><%= inv.client || '—' %></td>
          <td style="font-variant-numeric:tabular-nums;"><%= inv.amount.toLocaleString('cs-CZ') %> <%= inv.currency %></td>
          <td>
            <span class="badge" style="background:<%= inv.status === 'Zaplacena' ? 'var(--success-bg)' : inv.status === 'Po splatnosti' ? 'var(--danger-bg)' : 'var(--warning-bg)' %>;color:<%= inv.status === 'Zaplacena' ? '#15803D' : inv.status === 'Po splatnosti' ? '#991B1B' : '#92400E' %>;">
              <%= inv.status %>
            </span>
          </td>
          <td style="color:var(--text-muted);"><%= inv.due_date ? new Date(inv.due_date).toLocaleDateString('cs-CZ') : '—' %></td>
          <td style="color:var(--text-muted);font-size:12px;"><%= new Date(inv.date).toLocaleDateString('cs-CZ') %></td>
        </tr>
        <% }); %>
      <% } else { %>
      <tr>
        <td colspan="6" style="text-align:center;padding:48px;color:var(--text-muted);">Zatím žádné vydané faktury</td>
      </tr>
      <% } %>
    </tbody>
  </table>
</div>

<div class="modal-backdrop" id="modalCreateIssuedInvoice">
  <div class="modal modal-sm">
    <div class="modal-header">
      <h2 class="modal-title">Nová vydaná faktura</h2>
      <button class="modal-close" data-modal-close="modalCreateIssuedInvoice">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <form method="post" action="/ucetnictvi/vydane-faktury/vytvorit">
      <div class="modal-body">
        <div class="form-grid" style="grid-template-columns:1fr 1fr;gap:14px;">
          <div class="form-group">
            <label class="form-label required">Číslo faktury</label>
            <input type="text" name="number" class="form-control" required>
          </div>
          <div class="form-group">
            <label class="form-label">Datum</label>
            <input type="date" name="date" class="form-control" value="<%= new Date().toISOString().split('T')[0] %>">
          </div>
          <div class="form-group col-span-2">
            <label class="form-label">Odběratel</label>
            <input type="text" name="client" class="form-control" placeholder="Název odběratele">
          </div>
          <div class="form-group">
            <label class="form-label">Částka</label>
            <input type="number" name="amount" class="form-control" placeholder="0" step="0.01">
          </div>
          <div class="form-group">
            <label class="form-label">Měna</label>
            <select name="currency" class="form-select">
              <option value="CZK">CZK</option>
              <option value="EUR">EUR</option>
              <option value="USD">USD</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Splatnost</label>
            <input type="date" name="due_date" class="form-control">
          </div>
          <div class="form-group">
            <label class="form-label">Stav</label>
            <select name="status" class="form-select">
              <option value="Nezaplacena">Nezaplacena</option>
              <option value="Zaplacena">Zaplacena</option>
              <option value="Po splatnosti">Po splatnosti</option>
            </select>
          </div>
          <div class="form-group col-span-2">
            <label class="form-label">Poznámky</label>
            <textarea name="notes" class="form-control" rows="2"></textarea>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline" data-modal-close="modalCreateIssuedInvoice">Zrušit</button>
        <button type="submit" class="btn btn-primary">Uložit</button>
      </div>
    </form>
  </div>
</div>
