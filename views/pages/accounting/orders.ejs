<div class="page-header">
  <div class="page-header-left">
    <h1>Objednávky</h1>
    <p><%= total || 0 %> objednávek v systému</p>
  </div>
  <button class="btn btn-primary" data-modal-open="modalCreateOrder">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    Nová objednávka
  </button>
</div>

<div class="table-wrapper">
  <table class="data-table">
    <thead>
      <tr>
        <th>Číslo</th>
        <th>Předmět</th>
        <th>Firma</th>
        <th>Částka</th>
        <th>Stav</th>
        <th>Datum</th>
      </tr>
    </thead>
    <tbody>
      <% if (orders && orders.length > 0) { %>
        <% orders.forEach(o => { %>
        <tr>
          <td style="font-weight:500;font-family:monospace;"><%= o.number %></td>
          <td><%= o.subject || '—' %></td>
          <td style="color:var(--text-muted);"><%= o.company_name || '—' %></td>
          <td style="font-variant-numeric:tabular-nums;"><%= o.amount.toLocaleString('cs-CZ') %> <%= o.currency %></td>
          <td>
            <span class="badge" style="background:<%= o.status === 'Dokončena' ? 'var(--success-bg)' : o.status === 'Zrušena' ? 'var(--danger-bg)' : 'var(--warning-bg)' %>;color:<%= o.status === 'Dokončena' ? '#15803D' : o.status === 'Zrušena' ? '#991B1B' : '#92400E' %>;">
              <%= o.status %>
            </span>
          </td>
          <td style="color:var(--text-muted);font-size:12px;"><%= new Date(o.date).toLocaleDateString('cs-CZ') %></td>
        </tr>
        <% }); %>
      <% } else { %>
      <tr>
        <td colspan="6" style="text-align:center;padding:48px;color:var(--text-muted);">Zatím žádné objednávky</td>
      </tr>
      <% } %>
    </tbody>
  </table>
</div>

<!-- Modal: Nová objednávka -->
<div class="modal-backdrop" id="modalCreateOrder">
  <div class="modal modal-sm">
    <div class="modal-header">
      <h2 class="modal-title">Nová objednávka</h2>
      <button class="modal-close" data-modal-close="modalCreateOrder">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <form method="post" action="/ucetnictvi/objednavky/vytvorit">
      <div class="modal-body">
        <div class="form-grid" style="grid-template-columns:1fr 1fr;gap:14px;">
          <div class="form-group">
            <label class="form-label required">Číslo objednávky</label>
            <input type="text" name="number" class="form-control" placeholder="OBJ-2026-001" required>
          </div>
          <div class="form-group">
            <label class="form-label">Datum</label>
            <input type="date" name="date" class="form-control" value="<%= new Date().toISOString().split('T')[0] %>">
          </div>
          <div class="form-group col-span-2">
            <label class="form-label">Předmět</label>
            <input type="text" name="subject" class="form-control" placeholder="Popis objednávky">
          </div>
          <div class="form-group">
            <label class="form-label">Částka</label>
            <input type="number" name="amount" class="form-control" placeholder="0" step="0.01">
          </div>
          <div class="form-group">
            <label class="form-label">Měna</label>
            <select name="currency" class="form-select">
              <option value="CZK">CZK</option>
              <option value="EUR">EUR</option>
              <option value="USD">USD</option>
            </select>
          </div>
          <div class="form-group col-span-2">
            <label class="form-label">Firma</label>
            <select name="company_id" class="form-select">
              <option value="">— Bez firmy —</option>
              <% (companies || []).forEach(c => { %>
                <option value="<%= c.id %>"><%= c.name %></option>
              <% }); %>
            </select>
          </div>
          <div class="form-group col-span-2">
            <label class="form-label">Poznámky</label>
            <textarea name="notes" class="form-control" rows="2"></textarea>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline" data-modal-close="modalCreateOrder">Zrušit</button>
        <button type="submit" class="btn btn-primary">Uložit</button>
      </div>
    </form>
  </div>
</div>
