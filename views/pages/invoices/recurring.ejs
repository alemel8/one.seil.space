<div class="page-header">
  <div class="page-header-left">
    <h1>Šablony opakujících se faktur</h1>
    <p><%= templates.length %> šablon</p>
  </div>
  <button class="btn btn-primary" data-modal-open="modalCreate">+ Nová šablona</button>
</div>

<div class="table-wrapper">
  <table class="data-table">
    <thead>
      <tr>
        <th>Název šablony</th><th>Klient</th><th>Frekvence</th><th>Příští generování</th>
        <th>Posl. generování</th><th>Stav</th><th></th>
      </tr>
    </thead>
    <tbody>
      <% if (templates.length > 0) { %>
        <% templates.forEach(t => { %>
        <tr>
          <td style="font-weight:600;"><%= t.name %></td>
          <td style="font-size:13px;"><%= t.client_name || '—' %></td>
          <td>
            <%
              const freqLabel = t.frequency === 'monthly' ? 'Měsíčně' :
                                t.frequency === 'quarterly' ? 'Čtvrtletně' : 'Ročně';
            %>
            <span style="font-size:13px;"><%= freqLabel %>, <%= t.day_of_month %>. den</span>
          </td>
          <td style="font-size:13px;color:<%= t.active ? 'var(--text-primary)' : 'var(--text-muted)' %>;">
            <%= t.next_run_date ? new Date(t.next_run_date).toLocaleDateString('cs-CZ') : '—' %>
          </td>
          <td style="font-size:13px;color:var(--text-muted);">
            <%= t.last_run_date ? new Date(t.last_run_date).toLocaleDateString('cs-CZ') : 'Nikdy' %>
          </td>
          <td>
            <span class="badge" style="background:<%= t.active ? '#dcfce7' : '#f3f4f6' %>;color:<%= t.active ? '#166534' : '#6b7280' %>;">
              <%= t.active ? 'Aktivní' : 'Pozastavena' %>
            </span>
          </td>
          <td>
            <div style="display:flex;gap:4px;">
              <form method="post" action="/ucetnictvi/sablony-faktur/<%= t.id %>/toggle" style="display:inline;">
                <button type="submit" class="btn btn-ghost btn-sm" title="<%= t.active ? 'Pozastavit' : 'Aktivovat' %>">
                  <%= t.active ? '⏸' : '▶' %>
                </button>
              </form>
              <form method="post" action="/ucetnictvi/sablony-faktur/<%= t.id %>/smazat"
                    onsubmit="return confirm('Smazat šablonu?')" style="display:inline;">
                <button type="submit" class="btn btn-ghost btn-sm" style="color:var(--danger);" title="Smazat">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                    <path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
                  </svg>
                </button>
              </form>
            </div>
          </td>
        </tr>
        <% }) %>
      <% } else { %>
        <tr><td colspan="7" style="text-align:center;padding:48px;color:var(--text-muted);">
          Žádné šablony — vytvořte první kliknutím na „+ Nová šablona"
        </td></tr>
      <% } %>
    </tbody>
  </table>
</div>

<!-- Modal: Nová šablona -->
<div id="modalCreate" class="modal-backdrop">
  <div class="modal modal-lg">
    <div class="modal-header">
      <h2 class="modal-title">Nová šablona opakující se faktury</h2>
      <button class="modal-close" data-modal-close="modalCreate">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <form method="post" action="/ucetnictvi/sablony-faktur/vytvorit">
      <div class="modal-body" style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">

        <div class="form-group col-span-2">
          <label class="form-label required">Název šablony</label>
          <input type="text" name="name" class="form-control" placeholder="např. Hosting měsíční" required>
        </div>

        <div class="form-group">
          <label class="form-label required">Klient</label>
          <input type="text" name="client_name" class="form-control" required>
        </div>
        <div class="form-group">
          <label class="form-label">E-mail klienta (pro odeslání)</label>
          <input type="email" name="client_email" class="form-control" placeholder="nepovinné">
        </div>
        <div class="form-group">
          <label class="form-label">IČO klienta</label>
          <input type="text" name="client_ico" class="form-control">
        </div>
        <div class="form-group">
          <label class="form-label">DIČ klienta</label>
          <input type="text" name="client_dic" class="form-control">
        </div>
        <div class="form-group col-span-2">
          <label class="form-label">Adresa klienta</label>
          <input type="text" name="client_address" class="form-control">
        </div>

        <div class="form-group">
          <label class="form-label">Číselná řada</label>
          <select name="series_id" class="form-select">
            <option value="">— bez řady —</option>
            <% series.forEach(s => { %><option value="<%= s.id %>"><%= s.name %></option><% }) %>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Frekvence</label>
          <select name="frequency" class="form-select">
            <option value="monthly">Měsíčně</option>
            <option value="quarterly">Čtvrtletně</option>
            <option value="yearly">Ročně</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Den v měsíci</label>
          <input type="number" name="day_of_month" class="form-control" value="1" min="1" max="28">
        </div>
        <div class="form-group">
          <label class="form-label">Splatnost (dní)</label>
          <input type="number" name="due_days" class="form-control" value="14" min="1">
        </div>
        <div class="form-group">
          <label class="form-label">První generování</label>
          <input type="date" name="next_run_date" class="form-control" value="<%= new Date().toISOString().split('T')[0] %>">
        </div>
        <div class="form-group" style="display:flex;align-items:center;gap:8px;padding-top:24px;">
          <input type="checkbox" name="send_email" id="sendEmailCb" style="width:18px;height:18px;">
          <label for="sendEmailCb" style="margin:0;cursor:pointer;font-size:14px;">Automaticky odeslat emailem</label>
        </div>

        <!-- Položky faktury -->
        <div class="form-group col-span-2">
          <label class="form-label">Položky faktury</label>
          <div id="items-list" style="display:flex;flex-direction:column;gap:8px;">
            <div class="recur-item" style="display:grid;grid-template-columns:1fr 70px 100px 60px;gap:8px;align-items:center;">
              <input type="text" name="item_name[]" class="form-control" placeholder="Název položky" required>
              <input type="number" name="item_qty[]"   class="form-control" placeholder="Qty" value="1" min="0.01" step="0.01">
              <input type="number" name="item_price[]" class="form-control" placeholder="Cena/ks" min="0" step="0.01">
              <input type="number" name="item_vat[]"   class="form-control" placeholder="DPH%" value="21" min="0">
            </div>
          </div>
          <button type="button" class="btn btn-ghost btn-sm" style="margin-top:8px;" onclick="addRecurItem()">+ Přidat položku</button>
        </div>

      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-ghost" data-modal-close="modalCreate">Zrušit</button>
        <button type="submit" class="btn btn-primary">Vytvořit šablonu</button>
      </div>
    </form>
  </div>
</div>

<style>
.col-span-2 { grid-column: span 2; }
</style>

<script>
function addRecurItem() {
  const list = document.getElementById('items-list');
  const div  = document.createElement('div');
  div.className = 'recur-item';
  div.style.cssText = 'display:grid;grid-template-columns:1fr 70px 100px 60px;gap:8px;align-items:center;';
  div.innerHTML = `
    <input type="text"   name="item_name[]"  class="form-control" placeholder="Název položky">
    <input type="number" name="item_qty[]"   class="form-control" placeholder="Qty"   value="1" min="0.01" step="0.01">
    <input type="number" name="item_price[]" class="form-control" placeholder="Cena/ks" min="0" step="0.01">
    <input type="number" name="item_vat[]"   class="form-control" placeholder="DPH%"  value="21" min="0">
  `;
  list.appendChild(div);
}
</script>
