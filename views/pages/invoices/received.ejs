<div class="page-header">
  <div class="page-header-left">
    <h1>Přijaté faktury</h1>
    <p><%= total %> faktur celkem</p>
  </div>
  <button class="btn btn-primary" data-modal-open="modalCreate">+ Přidat fakturu</button>
</div>

<form method="get" style="display:flex;gap:10px;margin-bottom:20px;flex-wrap:wrap;">
  <input type="text" name="q" value="<%= q||'' %>" placeholder="Hledat číslo, dodavatel…" class="form-control" style="max-width:280px;">
  <select name="status" class="form-select" style="width:auto;">
    <option value="">Všechny stavy</option>
    <% STATUSES_RECEIVED.forEach(s => { %><option value="<%= s %>" <%= statusFilter===s?'selected':'' %>><%= s %></option><% }) %>
  </select>
  <button type="submit" class="btn btn-outline">Filtrovat</button>
  <% if (q||statusFilter) { %><a href="/ucetnictvi/prijate-faktury" class="btn btn-ghost">Zrušit</a><% } %>
</form>

<div class="table-wrapper">
  <table class="data-table">
    <thead>
      <tr>
        <th>Číslo</th><th>Dodavatel</th><th>Přijato</th><th>Splatnost</th>
        <th style="text-align:right;">Celkem</th><th>Stav</th><th></th>
      </tr>
    </thead>
    <tbody>
      <% if (invoices.length > 0) { %>
        <% invoices.forEach(inv => { %>
        <tr>
          <td style="font-weight:600;"><%= inv.number %></td>
          <td><%= inv.supplier || '—' %></td>
          <td style="color:var(--text-muted);font-size:13px;"><%= new Date(inv.issue_date).toLocaleDateString('cs-CZ') %></td>
          <td style="color:var(--text-muted);font-size:13px;"><%= inv.due_date ? new Date(inv.due_date).toLocaleDateString('cs-CZ') : '—' %></td>
          <td style="text-align:right;font-weight:600;"><%= Number(inv.total_amount).toLocaleString('cs-CZ',{minimumFractionDigits:2}) %> <%= inv.currency %></td>
          <td>
            <%
              const sc = inv.status==='Zaplacena' ? '#dcfce7:#166534' :
                         inv.status==='Po splatnosti' ? '#fee2e2:#991b1b' :
                         inv.status==='Storno' ? '#f3f4f6:#6b7280' : '#fef9c3:#92400e';
              const [bg,cl] = sc.split(':');
            %>
            <span class="badge" style="background:<%= bg %>;color:<%= cl %>;"><%= inv.status %></span>
          </td>
          <td>
            <form method="post" action="/ucetnictvi/prijate-faktury/<%= inv.id %>/stav" style="display:inline;">
              <select name="status" class="form-select" style="width:auto;padding:4px 8px;font-size:12px;" onchange="this.form.submit()">
                <% STATUSES_RECEIVED.forEach(s => { %><option value="<%= s %>" <%= inv.status===s?'selected':'' %>><%= s %></option><% }) %>
              </select>
            </form>
          </td>
        </tr>
        <% }) %>
      <% } else { %>
        <tr><td colspan="7" style="text-align:center;padding:40px;color:var(--text-muted);">Žádné přijaté faktury</td></tr>
      <% } %>
    </tbody>
  </table>
</div>

<!-- Modal: Nová přijatá faktura -->
<div id="modalCreate" class="modal-backdrop" onclick="if(event.target===this)rfClose()">
  <div class="modal rf-modal" id="rfModalInner">

    <div class="modal-header">
      <h2 class="modal-title" id="rfTitle">Přidat přijatou fakturu</h2>
      <button class="modal-close" onclick="rfClose()">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    <!-- ── Fáze 1: Upload ── -->
    <div id="rfPhaseUpload" class="modal-body">
      <div id="rfDropZone" class="rf-drop-zone">
        <input type="file" id="rfFileInput" accept="application/pdf" style="display:none">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
          <line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/>
        </svg>
        <p style="margin:12px 0 4px;font-weight:600;color:var(--text-primary);">Přetáhněte PDF fakturu sem</p>
        <p style="margin:0;font-size:13px;color:var(--text-muted);">nebo <button type="button" onclick="document.getElementById('rfFileInput').click()" style="background:none;border:none;color:var(--primary);font-size:13px;font-weight:600;cursor:pointer;padding:0;">vyberte soubor</button></p>
      </div>
      <div style="text-align:center;margin-top:16px;">
        <button type="button" class="btn btn-ghost btn-sm" onclick="rfShowForm(null)">Pokračovat bez PDF</button>
      </div>
    </div>

    <!-- ── Fáze 2: Načítání ── -->
    <div id="rfPhaseLoading" class="modal-body" style="display:none;text-align:center;padding:60px 24px;">
      <div class="rf-spinner"></div>
      <p style="margin-top:16px;color:var(--text-muted);font-size:14px;">Claude analyzuje fakturu…</p>
    </div>

    <!-- ── Fáze 3: PDF + formulář ── -->
    <div id="rfPhaseForm" style="display:none;flex:1;overflow:hidden;">
      <div style="display:flex;height:100%;">

        <!-- Levá polovina: PDF viewer -->
        <div style="flex:1;border-right:1px solid var(--border);background:var(--bg-page);display:flex;flex-direction:column;">
          <div style="padding:10px 14px;font-size:12px;font-weight:600;color:var(--text-muted);border-bottom:1px solid var(--border);text-transform:uppercase;letter-spacing:0.5px;">Náhled faktury</div>
          <embed id="rfPdfEmbed" src="" type="application/pdf" style="flex:1;width:100%;border:none;">
        </div>

        <!-- Pravá polovina: Formulář -->
        <div style="flex:0 0 400px;overflow-y:auto;">
          <form id="rfForm" method="post" action="/ucetnictvi/prijate-faktury/vytvorit">
            <div style="padding:20px;display:flex;flex-direction:column;gap:14px;">

              <div id="rfAiBadge" style="display:none;background:var(--primary-light);color:var(--primary-dark);border-radius:var(--radius-sm);padding:8px 12px;font-size:12px;font-weight:600;">
                ✦ Pole byla předvyplněna z PDF — zkontrolujte prosím hodnoty
              </div>

              <div class="form-group">
                <label class="form-label required">Číslo faktury</label>
                <input type="text" name="number" id="rfNumber" class="form-control" required>
              </div>
              <div class="form-group">
                <label class="form-label required">Dodavatel</label>
                <input type="text" name="supplier" id="rfSupplier" class="form-control" required>
              </div>
              <div class="form-group">
                <label class="form-label">IČO dodavatele</label>
                <input type="text" name="supplier_ico" id="rfSupplierIco" class="form-control" placeholder="Nepovinné">
              </div>
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                <div class="form-group">
                  <label class="form-label">Základ bez DPH</label>
                  <input type="number" name="amount" id="rfAmount" class="form-control" step="0.01" min="0" value="0">
                </div>
                <div class="form-group">
                  <label class="form-label">DPH</label>
                  <input type="number" name="vat_amount" id="rfVat" class="form-control" step="0.01" min="0" value="0">
                </div>
              </div>
              <div style="display:grid;grid-template-columns:1fr 80px;gap:12px;">
                <div class="form-group">
                  <label class="form-label">Celková částka</label>
                  <input type="number" name="total_amount" id="rfTotal" class="form-control" step="0.01" min="0" value="0">
                </div>
                <div class="form-group">
                  <label class="form-label">Měna</label>
                  <select name="currency" id="rfCurrency" class="form-select">
                    <option value="CZK">CZK</option>
                    <option value="EUR">EUR</option>
                    <option value="USD">USD</option>
                  </select>
                </div>
              </div>
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                <div class="form-group">
                  <label class="form-label">Datum přijetí</label>
                  <input type="date" name="issue_date" id="rfIssueDate" class="form-control" value="<%= new Date().toISOString().split('T')[0] %>">
                </div>
                <div class="form-group">
                  <label class="form-label">Datum splatnosti</label>
                  <input type="date" name="due_date" id="rfDueDate" class="form-control">
                </div>
              </div>
              <div class="form-group">
                <label class="form-label">Stav</label>
                <select name="status" class="form-select">
                  <option value="Nezaplacena">Nezaplacena</option>
                  <option value="Zaplacena">Zaplacena</option>
                  <option value="Po splatnosti">Po splatnosti</option>
                  <option value="Storno">Storno</option>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label">Poznámka / předmět plnění</label>
                <textarea name="notes" id="rfNotes" class="form-control" rows="3"></textarea>
              </div>
            </div>
            <div class="modal-footer" style="position:sticky;bottom:0;background:var(--bg-card);">
              <button type="button" class="btn btn-ghost" onclick="rfClose()">Zrušit</button>
              <button type="submit" class="btn btn-primary">Přidat fakturu</button>
            </div>
          </form>
        </div>

      </div>
    </div>

  </div>
</div>

<style>
.rf-modal {
  max-width: 520px;
  width: 95vw;
  transition: max-width 0.3s ease;
  display: flex;
  flex-direction: column;
  max-height: 90vh;
}
.rf-modal.rf-expanded {
  max-width: min(1200px, 96vw);
  height: 90vh;
}
.rf-drop-zone {
  border: 2px dashed var(--border-strong);
  border-radius: var(--radius-lg);
  padding: 48px 24px;
  text-align: center;
  cursor: pointer;
  transition: border-color 0.15s, background 0.15s;
}
.rf-drop-zone:hover, .rf-drop-zone.rf-over {
  border-color: var(--primary);
  background: var(--primary-light);
}
.rf-spinner {
  width: 40px; height: 40px;
  border: 3px solid var(--border);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: rf-spin 0.8s linear infinite;
  margin: 0 auto;
}
@keyframes rf-spin { to { transform: rotate(360deg); } }
</style>

<script>
(function () {
  const backdrop   = document.getElementById('modalCreate');
  const inner      = document.getElementById('rfModalInner');
  const phUpload   = document.getElementById('rfPhaseUpload');
  const phLoading  = document.getElementById('rfPhaseLoading');
  const phForm     = document.getElementById('rfPhaseForm');
  const fileInput  = document.getElementById('rfFileInput');
  const dropZone   = document.getElementById('rfDropZone');
  const embed      = document.getElementById('rfPdfEmbed');
  const aiBadge    = document.getElementById('rfAiBadge');
  let currentBlobUrl = null;

  // Open / close
  document.querySelectorAll('[data-modal-open="modalCreate"]').forEach(b =>
    b.addEventListener('click', rfOpen)
  );
  window.rfOpen = function () {
    backdrop.classList.add('open');
    rfReset();
  };
  window.rfClose = function () {
    backdrop.classList.remove('open');
    if (currentBlobUrl) { URL.revokeObjectURL(currentBlobUrl); currentBlobUrl = null; }
  };

  function rfReset() {
    inner.classList.remove('rf-expanded');
    phUpload.style.display  = '';
    phLoading.style.display = 'none';
    phForm.style.display    = 'none';
    fileInput.value         = '';
    aiBadge.style.display   = 'none';
    document.getElementById('rfForm').reset();
    // Reset issue_date to today
    document.getElementById('rfIssueDate').value = new Date().toISOString().split('T')[0];
  }

  // File input change
  fileInput.addEventListener('change', () => {
    if (fileInput.files[0]) handleFile(fileInput.files[0]);
  });

  // Drag & drop
  dropZone.addEventListener('click', () => fileInput.click());
  dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('rf-over'); });
  dropZone.addEventListener('dragleave', () => dropZone.classList.remove('rf-over'));
  dropZone.addEventListener('drop', e => {
    e.preventDefault();
    dropZone.classList.remove('rf-over');
    const f = e.dataTransfer?.files?.[0];
    if (f && f.type === 'application/pdf') handleFile(f);
  });

  async function handleFile(file) {
    // Show PDF in embed immediately
    if (currentBlobUrl) URL.revokeObjectURL(currentBlobUrl);
    currentBlobUrl = URL.createObjectURL(file);

    // Switch to loading phase
    phUpload.style.display  = 'none';
    phLoading.style.display = '';

    try {
      const fd = new FormData();
      fd.append('file', file, file.name);
      const resp = await fetch('/ucetnictvi/prijate-faktury/analyze-pdf', {
        method: 'POST', body: fd,
      });
      const data = await resp.json();
      if (!resp.ok) throw new Error(data.error || 'Chyba serveru');
      rfShowForm(data);
    } catch (err) {
      rfShowForm(null, err.message);
    }
  }

  window.rfShowForm = function (data, errMsg) {
    // Set PDF embed src
    if (currentBlobUrl) embed.setAttribute('src', currentBlobUrl);

    // Pre-fill fields
    if (data) {
      setVal('rfNumber',      data.number);
      setVal('rfSupplier',    data.supplier);
      setVal('rfSupplierIco', data.supplier_ico);
      setVal('rfAmount',      data.amount != null ? String(data.amount) : '');
      setVal('rfVat',         data.vat_amount != null ? String(data.vat_amount) : '');
      setVal('rfTotal',       data.total_amount != null ? String(data.total_amount) : '');
      setVal('rfIssueDate',   data.issue_date);
      setVal('rfDueDate',     data.due_date);
      setVal('rfNotes',       data.notes);
      if (document.getElementById('rfCurrency') && data.currency)
        document.getElementById('rfCurrency').value = data.currency;
      aiBadge.style.display = '';
    }
    if (errMsg) {
      aiBadge.style.display = '';
      aiBadge.style.background = 'var(--danger-bg)';
      aiBadge.style.color = 'var(--danger)';
      aiBadge.textContent = '⚠ ' + errMsg + ' — vyplňte pole ručně.';
    }

    // Expand modal and show form
    phLoading.style.display = 'none';
    phUpload.style.display  = 'none';
    inner.classList.add('rf-expanded');
    phForm.style.display = 'flex';
    phForm.style.flex    = '1';
    phForm.style.overflow = 'hidden';
  };

  function setVal(id, val) {
    const el = document.getElementById(id);
    if (el && val != null && val !== '') el.value = val;
  }
})();
</script>
