<div class="page-header">
  <div class="page-header-left">
    <h1>Přijaté faktury</h1>
    <p><%= total %> faktur celkem</p>
  </div>
  <button class="btn btn-primary" data-modal-open="modalCreate">+ Přidat fakturu</button>
</div>

<form method="get" style="display:flex;gap:10px;margin-bottom:20px;flex-wrap:wrap;">
  <input type="text" name="q" value="<%= q||'' %>" placeholder="Hledat číslo, dodavatel…" class="form-control" style="max-width:280px;">
  <select name="status" class="form-select" style="width:auto;">
    <option value="">Všechny stavy</option>
    <% STATUSES_RECEIVED.forEach(s => { %><option value="<%= s %>" <%= statusFilter===s?'selected':'' %>><%= s %></option><% }) %>
  </select>
  <button type="submit" class="btn btn-outline">Filtrovat</button>
  <% if (q||statusFilter) { %><a href="/ucetnictvi/prijate-faktury" class="btn btn-ghost">Zrušit</a><% } %>
</form>

<div class="table-wrapper">
  <table class="data-table">
    <thead>
      <tr>
        <th>Číslo</th><th>Dodavatel</th><th>Přijato</th><th>Splatnost</th>
        <th style="text-align:right;">Celkem</th><th>Stav</th><th></th>
      </tr>
    </thead>
    <tbody>
      <% if (invoices.length > 0) { %>
        <% invoices.forEach(inv => { %>
        <tr>
          <td style="font-weight:600;"><%= inv.number %></td>
          <td><%= inv.supplier || '—' %></td>
          <td style="color:var(--text-muted);font-size:13px;"><%= new Date(inv.issue_date).toLocaleDateString('cs-CZ') %></td>
          <td style="color:var(--text-muted);font-size:13px;"><%= inv.due_date ? new Date(inv.due_date).toLocaleDateString('cs-CZ') : '—' %></td>
          <td style="text-align:right;font-weight:600;"><%= Number(inv.total_amount).toLocaleString('cs-CZ',{minimumFractionDigits:2}) %> <%= inv.currency %></td>
          <td>
            <%
              const sc = inv.status==='Zaplacena' ? '#dcfce7:#166534' :
                         inv.status==='Po splatnosti' ? '#fee2e2:#991b1b' :
                         inv.status==='Storno' ? '#f3f4f6:#6b7280' : '#fef9c3:#92400e';
              const [bg,cl] = sc.split(':');
            %>
            <span class="badge" style="background:<%= bg %>;color:<%= cl %>;"><%= inv.status %></span>
          </td>
          <td>
            <form method="post" action="/ucetnictvi/prijate-faktury/<%= inv.id %>/stav" style="display:inline;">
              <select name="status" class="form-select" style="width:auto;padding:4px 8px;font-size:12px;" onchange="this.form.submit()">
                <% STATUSES_RECEIVED.forEach(s => { %><option value="<%= s %>" <%= inv.status===s?'selected':'' %>><%= s %></option><% }) %>
              </select>
            </form>
          </td>
        </tr>
        <% }) %>
      <% } else { %>
        <tr><td colspan="7" style="text-align:center;padding:40px;color:var(--text-muted);">Žádné přijaté faktury</td></tr>
      <% } %>
    </tbody>
  </table>
</div>

<!-- Modal: Nová přijatá faktura -->
<div id="modalCreate" class="modal-overlay" style="display:none;" onclick="if(event.target===this)this.style.display='none'">
  <div class="modal" style="max-width:480px;width:90%;">
    <div class="modal-header"><h3>Přidat přijatou fakturu</h3><button class="modal-close" onclick="document.getElementById('modalCreate').style.display='none'">&times;</button></div>
    <form method="post" action="/ucetnictvi/prijate-faktury/vytvorit">
      <div class="modal-body" style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
        <div class="form-group">
          <label class="form-label">Číslo faktury *</label>
          <input type="text" name="number" class="form-control" required>
        </div>
        <div class="form-group">
          <label class="form-label">Dodavatel *</label>
          <input type="text" name="supplier" class="form-control" required>
        </div>
        <div class="form-group">
          <label class="form-label">Celková částka</label>
          <input type="number" name="amount" class="form-control" step="0.01" min="0" value="0">
        </div>
        <div class="form-group">
          <label class="form-label">z toho DPH</label>
          <input type="number" name="vat_amount" class="form-control" step="0.01" min="0" value="0">
        </div>
        <div class="form-group">
          <label class="form-label">Datum přijetí</label>
          <input type="date" name="issue_date" class="form-control" value="<%= new Date().toISOString().split('T')[0] %>">
        </div>
        <div class="form-group">
          <label class="form-label">Datum splatnosti</label>
          <input type="date" name="due_date" class="form-control">
        </div>
        <div class="form-group" style="grid-column:1/-1;">
          <label class="form-label">Poznámka</label>
          <textarea name="notes" class="form-control" rows="2"></textarea>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-ghost" onclick="document.getElementById('modalCreate').style.display='none'">Zrušit</button>
        <button type="submit" class="btn btn-primary">Přidat fakturu</button>
      </div>
    </form>
  </div>
</div>

<script>
document.querySelectorAll('[data-modal-open]').forEach(btn => {
  btn.addEventListener('click', () => document.getElementById(btn.dataset.modalOpen).style.display = 'flex');
});
</script>
