<div class="page-header">
  <div class="page-header-left">
    <h1>Přijaté faktury</h1>
    <p><%= total %> faktur celkem</p>
  </div>
  <div style="display:flex;gap:8px;">
    <a href="/ucetnictvi/prijate-faktury/export.csv" class="btn btn-outline btn-sm">↓ CSV</a>
    <button class="btn btn-primary" onclick="rfOpen()">+ Přidat fakturu</button>
  </div>
</div>

<!-- Bulk action bar -->
<div id="bulkBar" style="display:none;position:sticky;top:0;z-index:50;background:var(--primary);color:#fff;padding:10px 16px;border-radius:var(--radius-md);margin-bottom:12px;align-items:center;gap:12px;">
  <span id="bulkCount" style="font-weight:600;font-size:14px;"></span>
  <form id="bulkPohodaForm" method="post" action="/ucetnictvi/prijate-faktury/pohoda-xml" style="display:inline;" target="_blank">
    <div id="bulkInputs"></div>
    <button type="submit" class="btn btn-sm" style="background:#fff;color:var(--primary);font-weight:600;">↓ Export POHODA XML</button>
  </form>
  <button type="button" class="btn btn-sm" style="background:rgba(255,255,255,0.2);color:#fff;" onclick="bulkClearAll()">Zrušit výběr</button>
</div>

<form method="get" style="display:flex;gap:10px;margin-bottom:20px;flex-wrap:wrap;">
  <input type="text" name="q" value="<%= q||'' %>" placeholder="Hledat číslo, dodavatel…" class="form-control" style="max-width:280px;">
  <select name="status" class="form-select" style="width:auto;">
    <option value="">Všechny stavy</option>
    <% STATUSES_RECEIVED.forEach(s => { %><option value="<%= s %>" <%= statusFilter===s?'selected':'' %>><%= s %></option><% }) %>
  </select>
  <button type="submit" class="btn btn-outline">Filtrovat</button>
  <% if (q||statusFilter) { %><a href="/ucetnictvi/prijate-faktury" class="btn btn-ghost">Zrušit</a><% } %>
</form>

<div class="table-wrapper">
  <table class="data-table">
    <thead>
      <tr>
        <th style="width:36px;"><input type="checkbox" id="bulkSelectAll" onchange="bulkToggleAll(this.checked)" title="Vybrat vše"></th>
        <th>Číslo</th><th>Dodavatel</th><th>Přijato</th><th>Splatnost</th>
        <th style="text-align:right;">Celkem</th><th>Stav</th><th></th>
      </tr>
    </thead>
    <tbody>
      <% if (invoices.length > 0) { %>
        <% invoices.forEach(inv => { %>
        <%
          const sc = inv.status==='Zaplacena' ? '#dcfce7:#166534' :
                     inv.status==='Po splatnosti' ? '#fee2e2:#991b1b' :
                     inv.status==='Storno' ? '#f3f4f6:#6b7280' : '#fef9c3:#92400e';
          const [bg,cl] = sc.split(':');
          const isOverdue = inv.due_date && inv.status !== 'Zaplacena' && inv.status !== 'Storno' && new Date(inv.due_date) < new Date();
        %>
        <tr style="cursor:pointer;" onclick="location.href='/ucetnictvi/prijate-faktury/<%= inv.id %>'">
          <td onclick="event.stopPropagation();">
            <input type="checkbox" class="bulk-cb" value="<%= inv.id %>" onchange="bulkUpdate()">
          </td>
          <td style="font-weight:600;"><%= inv.number %></td>
          <td><%= inv.supplier || '—' %></td>
          <td style="color:var(--text-muted);font-size:13px;"><%= new Date(inv.issue_date).toLocaleDateString('cs-CZ') %></td>
          <td style="color:var(--text-muted);font-size:13px;<%= isOverdue ? 'color:var(--danger);font-weight:500;' : '' %>">
            <%= inv.due_date ? new Date(inv.due_date).toLocaleDateString('cs-CZ') : '—' %>
            <% if (isOverdue) { %> ⚠<% } %>
          </td>
          <td style="text-align:right;font-weight:600;"><%= Number(inv.total_amount).toLocaleString('cs-CZ',{minimumFractionDigits:2}) %> <%= inv.currency %></td>
          <td><span class="badge" style="background:<%= bg %>;color:<%= cl %>;"><%= inv.status %></span></td>
          <td onclick="event.stopPropagation()">
            <form method="post" action="/ucetnictvi/prijate-faktury/<%= inv.id %>/stav" style="display:inline;">
              <input type="hidden" name="redirect_to" value="/ucetnictvi/prijate-faktury">
              <select name="status" class="form-select" style="width:auto;padding:4px 8px;font-size:12px;" onchange="this.form.submit()">
                <% STATUSES_RECEIVED.forEach(s => { %><option value="<%= s %>" <%= inv.status===s?'selected':'' %>><%= s %></option><% }) %>
              </select>
            </form>
          </td>
        </tr>
        <% }) %>
      <% } else { %>
        <tr><td colspan="8" style="text-align:center;padding:40px;color:var(--text-muted);">Žádné přijaté faktury</td></tr>
      <% } %>
    </tbody>
  </table>
</div>

<script>
function bulkUpdate() {
  const cbs = document.querySelectorAll('.bulk-cb:checked');
  const bar = document.getElementById('bulkBar');
  const inp = document.getElementById('bulkInputs');
  document.getElementById('bulkCount').textContent = `${cbs.length} vybráno`;
  inp.innerHTML = [...cbs].map(c => `<input type="hidden" name="ids" value="${c.value}">`).join('');
  bar.style.display = cbs.length > 0 ? 'flex' : 'none';
  const allCbs = document.querySelectorAll('.bulk-cb');
  document.getElementById('bulkSelectAll').checked = cbs.length === allCbs.length && allCbs.length > 0;
  document.getElementById('bulkSelectAll').indeterminate = cbs.length > 0 && cbs.length < allCbs.length;
}
function bulkToggleAll(checked) {
  document.querySelectorAll('.bulk-cb').forEach(c => c.checked = checked);
  bulkUpdate();
}
function bulkClearAll() {
  document.querySelectorAll('.bulk-cb').forEach(c => c.checked = false);
  document.getElementById('bulkSelectAll').checked = false;
  bulkUpdate();
}
</script>

<!-- Modal: Nová přijatá faktura -->
<input type="file" id="rfFileInput" accept="application/pdf,image/*" style="display:none">

<div id="modalCreate" class="modal-backdrop" onclick="if(event.target===this)rfClose()">
  <div class="modal rf-modal" id="rfModalInner">

    <div class="modal-header">
      <h2 class="modal-title">Přidat přijatou fakturu</h2>
      <button class="modal-close" onclick="rfClose()">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    <!-- ── Fáze 1: Upload ── -->
    <div id="rfPhaseUpload" class="modal-body" style="padding:32px 28px;">
      <label for="rfFileInput" class="rf-drop-zone" id="rfDropZone">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
          <line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/>
        </svg>
        <p style="margin:12px 0 4px;font-weight:600;color:var(--text-primary);font-size:15px;">Nahrát fakturu</p>
        <p style="margin:0;font-size:13px;color:var(--text-muted);">PDF nebo foto — přetáhněte nebo klikněte</p>
      </label>
    </div>

    <!-- ── Fáze 2: Načítání AI ── -->
    <div id="rfPhaseLoading" class="modal-body" style="display:none;text-align:center;padding:60px 24px;">
      <div class="rf-spinner"></div>
      <p style="margin-top:16px;color:var(--text-muted);font-size:14px;">Analyzuji fakturu…</p>
    </div>

    <!-- ── Fáze 3: 2-sloupcový layout ── -->
    <div id="rfPhaseForm" style="display:none;flex:1;min-height:0;overflow:hidden;flex-direction:row;align-items:stretch;">
      <div class="rf-split">

        <!-- Levá část: náhled dokumentu -->
        <div class="rf-left">
          <!-- Zoom toolbar -->
          <div class="rf-zoom-bar">
            <button type="button" id="rfZoomOut" class="rf-zoom-btn" onclick="rfZoomStep(-1)" title="Oddálit">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </button>
            <span id="rfZoomLabel" style="font-size:12px;font-weight:600;color:var(--text-muted);min-width:38px;text-align:center;">100%</span>
            <button type="button" id="rfZoomIn" class="rf-zoom-btn" onclick="rfZoomStep(1)" title="Přiblížit">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </button>
            <button type="button" id="rfZoomFit" class="rf-zoom-btn rf-zoom-fit" onclick="rfZoomReset()" title="Celý dokument" style="display:none;font-size:11px;padding:0 8px;gap:4px;">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/></svg>
              Celý dokument
            </button>
          </div>
          <!-- Preview area -->
          <div id="rfPreviewScroll" style="flex:1;overflow:auto;">
            <iframe id="rfIframe" src="about:blank" style="display:none;width:100%;border:none;"></iframe>
            <img id="rfImgPreview" src="" alt="" style="display:none;width:100%;height:auto;display:block;">
          </div>
        </div>

        <!-- Pravá část: formulář -->
        <div class="rf-right">
          <!-- Horní lišta s AI tlačítkem -->
          <div style="padding:10px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:flex-end;flex-shrink:0;">
            <button type="button" id="rfAiBtn" class="btn btn-outline btn-sm" onclick="rfRunAi()" style="display:flex;align-items:center;gap:6px;font-size:12px;">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
              Vytěžit automaticky
            </button>
          </div>

          <form id="rfForm" method="post" action="/ucetnictvi/prijate-faktury/vytvorit" style="flex:1;display:flex;flex-direction:column;min-height:0;">
            <div style="padding:16px;display:flex;flex-direction:column;gap:12px;flex:1;overflow-y:auto;">

              <div id="rfAiBadge" style="display:none;border-radius:var(--radius-sm);padding:8px 12px;font-size:12px;font-weight:600;"></div>

              <div class="form-group">
                <label class="form-label required">Číslo faktury</label>
                <input type="text" name="number" id="rfNumber" class="form-control" required>
              </div>

              <!-- IČO s ARES lookup -->
              <div class="form-group">
                <label class="form-label">IČO dodavatele</label>
                <div style="position:relative;">
                  <input type="text" name="supplier_ico" id="rfSupplierIco" class="form-control"
                    placeholder="např. 12345678"
                    oninput="rfAresDebounce(this.value)"
                    style="padding-right:36px;">
                  <div id="rfAresSpinner" style="display:none;position:absolute;right:10px;top:50%;transform:translateY(-50%);">
                    <div style="width:14px;height:14px;border:2px solid var(--border);border-top-color:var(--primary);border-radius:50%;animation:rf-spin 0.7s linear infinite;"></div>
                  </div>
                </div>
                <div id="rfAresBadge" style="display:none;margin-top:6px;font-size:12px;padding:6px 10px;border-radius:var(--radius-sm);"></div>
              </div>

              <div class="form-group">
                <label class="form-label required">Dodavatel</label>
                <input type="text" name="supplier" id="rfSupplier" class="form-control" required>
              </div>

              <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
                <div class="form-group">
                  <label class="form-label">Základ bez DPH</label>
                  <input type="number" name="amount" id="rfAmount" class="form-control" step="0.01" min="0" value="0">
                </div>
                <div class="form-group">
                  <label class="form-label">DPH</label>
                  <input type="number" name="vat_amount" id="rfVat" class="form-control" step="0.01" min="0" value="0">
                </div>
              </div>
              <div style="display:grid;grid-template-columns:1fr 80px;gap:10px;">
                <div class="form-group">
                  <label class="form-label">Celková částka</label>
                  <input type="number" name="total_amount" id="rfTotal" class="form-control" step="0.01" min="0" value="0">
                </div>
                <div class="form-group">
                  <label class="form-label">Měna</label>
                  <select name="currency" id="rfCurrency" class="form-select">
                    <option value="CZK">CZK</option>
                    <option value="EUR">EUR</option>
                    <option value="USD">USD</option>
                  </select>
                </div>
              </div>
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
                <div class="form-group">
                  <label class="form-label">Datum přijetí</label>
                  <input type="date" name="issue_date" id="rfIssueDate" class="form-control" value="<%= new Date().toISOString().split('T')[0] %>">
                </div>
                <div class="form-group">
                  <label class="form-label">Splatnost</label>
                  <input type="date" name="due_date" id="rfDueDate" class="form-control">
                </div>
              </div>
              <div class="form-group">
                <label class="form-label">Stav</label>
                <select name="status" class="form-select">
                  <option value="Nezaplacena">Nezaplacena</option>
                  <option value="Zaplacena">Zaplacena</option>
                  <option value="Po splatnosti">Po splatnosti</option>
                  <option value="Storno">Storno</option>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label">Poznámka / předmět plnění</label>
                <textarea name="notes" id="rfNotes" class="form-control" rows="2"></textarea>
              </div>
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
                <div class="form-group">
                  <label class="form-label">Předkontace MD</label>
                  <input type="text" name="account_debit" id="rfAccountDebit" class="form-control" placeholder="518" list="rfAcList" autocomplete="off">
                </div>
                <div class="form-group">
                  <label class="form-label">Předkontace D</label>
                  <input type="text" name="account_credit" id="rfAccountCredit" class="form-control" placeholder="321" list="rfAcList" autocomplete="off">
                </div>
              </div>
              <datalist id="rfAcList"></datalist>
            </div>

            <div class="modal-footer" style="border-top:1px solid var(--border);background:var(--bg-card);flex-shrink:0;">
              <button type="button" class="btn btn-ghost" onclick="rfClose()">Zrušit</button>
              <button type="submit" class="btn btn-primary">Přidat fakturu</button>
            </div>
          </form>
        </div>

      </div>
    </div>

  </div>
</div>

<style>
.rf-modal {
  max-width: 500px;
  width: 96vw;
  display: flex;
  flex-direction: column;
  max-height: 92vh;
  transition: max-width 0.25s ease, height 0.25s ease;
}
.rf-modal.rf-expanded {
  max-width: min(1160px, 96vw);
  height: 90vh;
}
.rf-drop-zone {
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 2px dashed var(--border-strong);
  border-radius: var(--radius-lg);
  padding: 48px 24px;
  text-align: center;
  cursor: pointer;
  transition: border-color 0.15s, background 0.15s;
  user-select: none;
}
.rf-drop-zone:hover, .rf-drop-zone.rf-over {
  border-color: var(--primary);
  background: var(--primary-light, rgba(79,70,229,0.04));
}
/* Dvousloupec — 50/50 */
.rf-split {
  display: flex;
  flex: 1;           /* musí vyplnit #rfPhaseForm do šířky i výšky */
  min-height: 0;
  width: 100%;
}
.rf-left {
  flex: 1;
  border-right: 1px solid var(--border);
  background: var(--bg-page, #f8f9fa);
  display: flex;
  flex-direction: column;
  min-width: 0;
  min-height: 0;
  overflow: hidden;
}
.rf-right {
  flex: 1;           /* 50/50 split */
  display: flex;
  flex-direction: column;
  min-height: 0;
  overflow: hidden;
}
/* Zoom toolbar */
.rf-zoom-bar {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 6px 12px;
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
  background: var(--bg-card);
}
.rf-zoom-btn {
  width: 28px;
  height: 28px;
  border: 1px solid var(--border);
  background: var(--bg-card);
  border-radius: var(--radius-sm, 6px);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-muted);
  transition: background 0.15s, color 0.15s;
  padding: 0;
}
.rf-zoom-btn:hover { background: var(--bg-page); color: var(--text-primary); }
.rf-zoom-btn:disabled { opacity: 0.35; cursor: default; }
.rf-zoom-fit { width: auto; }
/* Mobile: svisle */
@media (max-width: 700px) {
  .rf-modal.rf-expanded { height: 95vh; }
  .rf-split { flex-direction: column; }
  .rf-left { flex: 0 0 42vh; border-right: none; border-bottom: 1px solid var(--border); }
  .rf-right { flex: 1; min-height: 0; }
}
.rf-spinner {
  width: 40px; height: 40px;
  border: 3px solid var(--border);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: rf-spin 0.8s linear infinite;
  margin: 0 auto;
}
@keyframes rf-spin { to { transform: rotate(360deg); } }
</style>

<script>
(function () {
  const backdrop      = document.getElementById('modalCreate');
  const inner         = document.getElementById('rfModalInner');
  const phUpload      = document.getElementById('rfPhaseUpload');
  const phLoading     = document.getElementById('rfPhaseLoading');
  const phForm        = document.getElementById('rfPhaseForm');
  const fileInput     = document.getElementById('rfFileInput');
  const dropZone      = document.getElementById('rfDropZone');
  const iframe        = document.getElementById('rfIframe');
  const imgPreview    = document.getElementById('rfImgPreview');
  const aiBadge       = document.getElementById('rfAiBadge');
  const aiBtn         = document.getElementById('rfAiBtn');
  const zoomLabel     = document.getElementById('rfZoomLabel');
  const zoomFitBtn    = document.getElementById('rfZoomFit');
  const zoomInBtn     = document.getElementById('rfZoomIn');
  const zoomOutBtn    = document.getElementById('rfZoomOut');
  const previewScroll = document.getElementById('rfPreviewScroll');
  let currentFile     = null;
  let currentBlobUrl  = null;
  let zoomIdx         = 2;

  // ── Open / close ──────────────────────────────────────────
  // rfOpen je voláno přímo z onclick atributu tlačítka — musí být na window
  window.rfOpen = function () {
    backdrop.classList.add('open');
    document.body.style.overflow = 'hidden';
    rfReset();
  };
  window.rfClose = function () {
    backdrop.classList.remove('open');
    document.body.style.overflow = '';
    if (currentBlobUrl) { URL.revokeObjectURL(currentBlobUrl); currentBlobUrl = null; }
    currentFile = null;
  };

  function rfReset() {
    inner.classList.remove('rf-expanded');
    phUpload.style.display   = 'block';
    phLoading.style.display  = 'none';
    phForm.style.display     = 'none';
    fileInput.value          = '';
    aiBadge.style.display    = 'none';
    iframe.src               = 'about:blank';
    iframe.style.display     = 'none';
    iframe.style.zoom        = '';
    imgPreview.src           = '';
    imgPreview.style.display = 'none';
    imgPreview.style.zoom    = '';
    document.getElementById('rfAresBadge').style.display = 'none';
    document.getElementById('rfForm').reset();
    document.getElementById('rfIssueDate').value = new Date().toISOString().split('T')[0];
    zoomIdx = 2; baseW = 0; baseH = 0;
    if (zoomLabel) { zoomLabel.textContent = '100%'; zoomFitBtn.style.display = 'none'; }
  }

  // ── File input + drag & drop ──────────────────────────────
  fileInput.addEventListener('change', () => {
    if (fileInput.files[0]) handleFile(fileInput.files[0]);
  });

  dropZone.addEventListener('dragover',  e => { e.preventDefault(); dropZone.classList.add('rf-over'); });
  dropZone.addEventListener('dragleave', () => dropZone.classList.remove('rf-over'));
  dropZone.addEventListener('drop', e => {
    e.preventDefault();
    dropZone.classList.remove('rf-over');
    const f = e.dataTransfer?.files?.[0];
    if (f) handleFile(f);
  });

  // ── Zoom ─────────────────────────────────────────────────
  // Panel zůstane pevný. Iframe/img se zvětšuje → panel scrolluje.
  const ZOOM_STEPS = [50, 75, 100, 125, 150, 175, 200];
  let baseW = 0; // šířka panelu při 100 %
  let baseH = 0; // výška panelu při 100 %

  function rfApplyZoom() {
    const level = ZOOM_STEPS[zoomIdx];
    zoomLabel.textContent    = level + '%';
    zoomFitBtn.style.display = level !== 100 ? 'flex' : 'none';
    zoomInBtn.disabled       = zoomIdx === ZOOM_STEPS.length - 1;
    zoomOutBtn.disabled      = zoomIdx === 0;

    const scale   = level / 100;
    const isPdf   = currentFile?.type === 'application/pdf';
    const el      = isPdf ? iframe : imgPreview;

    if (!baseW) {
      baseW = previewScroll.clientWidth  || 600;
      baseH = previewScroll.clientHeight || 800;
    }

    const w = Math.round(baseW * scale);
    const h = Math.round(baseH * scale);

    if (isPdf) {
      // Iframe se fyzicky zvětší → PDF viewer uvnitř překreslí stránku na novou velikost
      el.style.width  = w + 'px';
      el.style.height = h + 'px';
    } else {
      // Obrázek: zachovat poměr stran
      el.style.width  = w + 'px';
      el.style.height = 'auto';
    }
  }

  window.rfZoomStep = function (dir) {
    zoomIdx = Math.max(0, Math.min(ZOOM_STEPS.length - 1, zoomIdx + dir));
    rfApplyZoom();
  };
  window.rfZoomReset = function () { zoomIdx = 2; rfApplyZoom(); };

  function handleFile(file) {
    currentFile = file;
    if (currentBlobUrl) URL.revokeObjectURL(currentBlobUrl);
    currentBlobUrl = URL.createObjectURL(file);

    phUpload.style.display = 'none';
    inner.classList.add('rf-expanded');
    phForm.style.display       = 'flex';
    phForm.style.flex          = '1';
    phForm.style.minHeight     = '0';
    phForm.style.flexDirection = 'row';
    phForm.style.alignItems    = 'stretch';
    phForm.style.overflow      = 'hidden';

    // Zobraz preview element
    if (file.type === 'application/pdf') {
      iframe.style.display     = 'block';
      imgPreview.style.display = 'none';
      iframe.src               = currentBlobUrl;
    } else {
      imgPreview.style.display = 'block';
      iframe.style.display     = 'none';
      imgPreview.src           = currentBlobUrl;
    }

    // Počkej na renderování layoutu, pak zachyť rozměry a nastav 100 % zoom
    zoomIdx = 2;
    baseW = 0;
    baseH = 0;
    setTimeout(rfApplyZoom, 80);
  }

  // ── AI vytěžení (na klik) ────────────────────────────────
  window.rfRunAi = async function () {
    if (!currentFile) return;
    aiBtn.disabled = true;
    aiBtn.textContent = 'Analyzuji…';
    aiBadge.style.display = 'none';

    try {
      const fd = new FormData();
      fd.append('file', currentFile, currentFile.name);
      const resp = await fetch('/ucetnictvi/prijate-faktury/analyze-pdf', { method: 'POST', body: fd });
      const data = await resp.json();
      if (!resp.ok) throw new Error(data.error || 'Chyba serveru');

      setVal('rfNumber',      data.number);
      setVal('rfSupplier',    data.supplier);
      setVal('rfSupplierIco', data.supplier_ico);
      setVal('rfAmount',      data.amount      != null ? String(data.amount)       : '');
      setVal('rfVat',         data.vat_amount  != null ? String(data.vat_amount)   : '');
      setVal('rfTotal',       data.total_amount != null ? String(data.total_amount) : '');
      setVal('rfIssueDate',   data.issue_date);
      setVal('rfDueDate',     data.due_date);
      setVal('rfNotes',       data.notes);
      if (data.currency) document.getElementById('rfCurrency').value = data.currency;

      aiBadge.style.cssText = 'display:block;background:var(--primary-light,rgba(79,70,229,0.08));color:var(--primary-dark,var(--primary));border-radius:var(--radius-sm);padding:8px 12px;font-size:12px;font-weight:600;margin-bottom:4px;';
      aiBadge.textContent = '✦ Pole byla předvyplněna — zkontrolujte prosím hodnoty';
    } catch (err) {
      aiBadge.style.cssText = 'display:block;background:var(--danger-bg);color:var(--danger);border-radius:var(--radius-sm);padding:8px 12px;font-size:12px;font-weight:600;margin-bottom:4px;';
      aiBadge.textContent = '⚠ ' + err.message;
    }

    aiBtn.disabled = false;
    aiBtn.innerHTML = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg> Vytěžit automaticky';
  };

  function setVal(id, val) {
    const el = document.getElementById(id);
    if (el && val != null && val !== '' && val !== 'null') el.value = val;
  }

  // Předkontace autocomplete
  fetch('/api/accounting-chart').then(r => r.json()).then(list => {
    const dl = document.getElementById('rfAcList');
    if (dl) dl.innerHTML = list.map(a => `<option value="${a.code}">${a.code} — ${a.name}</option>`).join('');
  }).catch(() => {});

  // ── ARES lookup ──────────────────────────────────────────
  const aresBadge   = document.getElementById('rfAresBadge');
  const aresSpinner = document.getElementById('rfAresSpinner');
  let aresTimer     = null;

  window.rfAresDebounce = function (val) {
    clearTimeout(aresTimer);
    const ico = val.replace(/\D/g, '');
    if (ico.length < 6) { aresBadge.style.display = 'none'; return; }
    aresTimer = setTimeout(() => rfAresFetch(ico), 600);
  };

  async function rfAresFetch(ico) {
    aresSpinner.style.display = 'block';
    aresBadge.style.display   = 'none';
    try {
      const res  = await fetch(`/api/ares/${ico}`);
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Nenalezeno');

      // Vyplň název dodavatele pokud je prázdný
      const supplierEl = document.getElementById('rfSupplier');
      if (supplierEl && (!supplierEl.value || supplierEl.value.trim() === '')) {
        supplierEl.value = data.name || '';
      }

      // Zobraz potvrzení s adresou
      const addr = [data.address, data.city, data.zip].filter(Boolean).join(', ');
      aresBadge.style.cssText = 'display:block;background:#dcfce7;color:#166534;border-radius:var(--radius-sm);padding:6px 10px;font-size:12px;';
      aresBadge.innerHTML = `<strong>${data.name}</strong>${addr ? '<br><span style="opacity:.8;">' + addr + '</span>' : ''}`;
    } catch (err) {
      aresBadge.style.cssText = 'display:block;background:var(--danger-bg);color:var(--danger);border-radius:var(--radius-sm);padding:6px 10px;font-size:12px;';
      aresBadge.textContent = err.message;
    }
    aresSpinner.style.display = 'none';
  }
})();
</script>
