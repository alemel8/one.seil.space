<div style="display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:60vh;text-align:center;gap:16px;">
  <div style="font-size:72px;font-weight:800;color:var(--border-strong);line-height:1;">404</div>
  <h1 style="font-size:22px;font-weight:600;color:var(--text-primary);margin:0;">Stránka nenalezena</h1>
  <p style="color:var(--text-muted);font-size:14px;max-width:380px;margin:0;">
    Stránka <strong style="color:var(--text-primary);"><%= url %></strong> neexistuje nebo byla přesunuta.
  </p>
  <a href="/" class="btn btn-primary" style="margin-top:8px;">← Zpět na přehled</a>
</div>
