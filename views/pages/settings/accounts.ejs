<div class="page-header">
  <div class="page-header-left">
    <h1>Účetní osnova</h1>
    <p>Číselník účtů pro předkontaci dokladů (<%= accounts.length %> účtů)</p>
  </div>
  <button class="btn btn-primary" data-modal-open="modalCreate">+ Přidat účet</button>
</div>

<% if (saved) { %>
<div style="background:var(--success-bg);color:var(--success);border-radius:var(--radius-md);padding:10px 16px;margin-bottom:16px;font-size:14px;font-weight:500;">
  Uloženo.
</div>
<% } %>

<div class="table-wrapper">
  <table class="data-table">
    <thead>
      <tr>
        <th style="width:100px;">Kód</th>
        <th>Název</th>
        <th style="width:100px;">Stav</th>
        <th style="width:80px;"></th>
      </tr>
    </thead>
    <tbody>
      <% if (accounts.length > 0) { %>
        <% accounts.forEach(a => { %>
        <tr>
          <td style="font-weight:700;font-size:15px;color:var(--primary);font-family:var(--font-mono);"><%= a.code %></td>
          <td><%= a.name %></td>
          <td>
            <span class="badge" style="background:<%= a.active ? '#dcfce7' : '#f3f4f6' %>;color:<%= a.active ? '#166534' : '#6b7280' %>;">
              <%= a.active ? 'Aktivní' : 'Neaktivní' %>
            </span>
          </td>
          <td>
            <div style="display:flex;gap:4px;">
              <form method="post" action="/nastaveni/ucetni-osnova/<%= a.id %>/toggle" style="display:inline;">
                <button type="submit" class="btn btn-ghost btn-sm" title="<%= a.active ? 'Deaktivovat' : 'Aktivovat' %>">
                  <%= a.active ? '⏸' : '▶' %>
                </button>
              </form>
              <form method="post" action="/nastaveni/ucetni-osnova/<%= a.id %>/smazat"
                    onsubmit="return confirm('Smazat účet <%= a.code %>?')" style="display:inline;">
                <button type="submit" class="btn btn-ghost btn-sm" style="color:var(--danger);" title="Smazat">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                    <path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
                  </svg>
                </button>
              </form>
            </div>
          </td>
        </tr>
        <% }) %>
      <% } else { %>
        <tr><td colspan="4" style="text-align:center;padding:40px;color:var(--text-muted);">Žádné účty</td></tr>
      <% } %>
    </tbody>
  </table>
</div>

<!-- Modal: Přidat účet -->
<div id="modalCreate" class="modal-backdrop">
  <div class="modal modal-sm">
    <div class="modal-header">
      <h2 class="modal-title">Přidat účet</h2>
      <button class="modal-close" data-modal-close="modalCreate">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <form method="post" action="/nastaveni/ucetni-osnova/vytvorit">
      <div class="modal-body" style="display:flex;flex-direction:column;gap:14px;">
        <div class="form-group">
          <label class="form-label required">Kód účtu</label>
          <input type="text" name="code" class="form-control" placeholder="např. 321" pattern="[0-9]{3,6}" required>
          <div style="font-size:12px;color:var(--text-muted);margin-top:4px;">3–6 číslic dle účetní osnovy</div>
        </div>
        <div class="form-group">
          <label class="form-label required">Název</label>
          <input type="text" name="name" class="form-control" placeholder="např. Závazky z obchodního styku" required>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-ghost" data-modal-close="modalCreate">Zrušit</button>
        <button type="submit" class="btn btn-primary">Přidat</button>
      </div>
    </form>
  </div>
</div>
