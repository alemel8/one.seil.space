<div class="page-header">
  <div class="page-header-left">
    <h1><a href="/nastaveni/eshopy" style="color:var(--text-muted);text-decoration:none;">Eshopy</a> / <%= shop.name %></h1>
    <p><%= shop.url || '—' %> · <code style="background:var(--gray-100);padding:2px 6px;border-radius:4px;font-size:12px;"><%= shop.slug %></code></p>
  </div>
  <button class="btn btn-primary" data-modal-open="modalAddCheck">+ Healthcheck</button>
</div>

<% if (saved) { %>
<div class="alert alert-success" style="background:#dcfce7;color:#166534;border:1px solid #bbf7d0;padding:12px 16px;border-radius:8px;margin-bottom:20px;">✓ Uloženo</div>
<% } %>

<% if (newKey) { %>
<div style="background:#fef9c3;border:1px solid #fde047;border-radius:8px;padding:16px;margin-bottom:20px;">
  <strong>Nový API klíč (zobrazí se pouze jednou!):</strong><br>
  <code style="font-family:var(--font-mono);font-size:14px;word-break:break-all;display:block;margin-top:8px;padding:8px;background:white;border-radius:4px;border:1px solid #e5e7eb;"><%= newKey %></code>
</div>
<% } %>

<div style="display:grid;grid-template-columns:2fr 1fr;gap:24px;">

  <div style="display:flex;flex-direction:column;gap:20px;">

    <!-- Healthchecky -->
    <div class="card">
      <div class="card-header">Healthchecky</div>
      <div class="table-wrapper" style="border:none;border-radius:0;">
        <table class="data-table">
          <thead><tr><th>Název</th><th>URL</th><th>Stav</th><th>Posl. kontrola</th><th></th></tr></thead>
          <tbody>
            <% if (checks.length > 0) { %>
              <% checks.forEach(c => { %>
              <tr>
                <td style="font-weight:600;"><%= c.name %></td>
                <td style="font-size:12px;color:var(--text-muted);font-family:var(--font-mono);"><%= c.url %></td>
                <td>
                  <% if (!c.active) { %>
                    <span class="badge" style="background:var(--gray-100);color:var(--gray-500);">Pozastaveno</span>
                  <% } else if (c.ok === true) { %>
                    <span class="badge" style="background:var(--success-bg);color:#15803D;">OK</span>
                  <% } else if (c.ok === false) { %>
                    <span class="badge" style="background:var(--danger-bg);color:#991B1B;">Výpadek</span>
                  <% } else { %>
                    <span class="badge" style="background:var(--gray-100);color:var(--gray-500);">Čeká se</span>
                  <% } %>
                </td>
                <td style="font-size:12px;color:var(--text-muted);"><%= c.checked_at ? new Date(c.checked_at).toLocaleString('cs-CZ') : '—' %></td>
                <td style="display:flex;gap:6px;">
                  <form method="post" action="/nastaveni/healthchecky/<%= c.id %>/toggle" style="display:inline;">
                    <input type="hidden" name="returnTo" value="/nastaveni/eshopy/<%= shop.id %>">
                    <button type="submit" class="btn btn-ghost btn-sm"><%= c.active ? '⏸' : '▶' %></button>
                  </form>
                  <form method="post" action="/nastaveni/healthchecky/<%= c.id %>/smazat" style="display:inline;" onsubmit="return confirm('Smazat?')">
                    <input type="hidden" name="returnTo" value="/nastaveni/eshopy/<%= shop.id %>">
                    <button type="submit" class="btn btn-ghost btn-sm" style="color:var(--danger);">🗑</button>
                  </form>
                </td>
              </tr>
              <% }) %>
            <% } else { %>
              <tr><td colspan="5" style="text-align:center;padding:32px;color:var(--text-muted);">Žádný healthcheck — přidej URL pro sledování dostupnosti.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Alert pravidla (app down) -->
    <div class="card">
      <div class="card-header" style="display:flex;justify-content:space-between;align-items:center;">
        <span>Alerty při výpadku (App down)</span>
        <button class="btn btn-outline btn-sm" data-modal-open="modalAddRule">+ Přidat</button>
      </div>
      <div class="card-body" style="font-size:12px;color:var(--text-muted);padding-bottom:0;">Pravidlo je globální — platí pro výpadek libovolné sledované aplikace.</div>
      <div class="table-wrapper" style="border:none;border-radius:0;">
        <table class="data-table">
          <thead><tr><th>Kanál</th><th></th></tr></thead>
          <tbody>
            <% if (rules.length > 0) { %>
              <% rules.forEach(r => { %>
              <tr>
                <td><%= r.channel_name || '—' %></td>
                <td>
                  <form method="post" action="/nastaveni/notifikace/pravidlo/<%= r.id %>/smazat" style="display:inline;" onsubmit="return confirm('Smazat?')">
                    <input type="hidden" name="returnTo" value="/nastaveni/eshopy/<%= shop.id %>">
                    <button type="submit" class="btn btn-ghost btn-sm" style="color:var(--danger);">🗑</button>
                  </form>
                </td>
              </tr>
              <% }) %>
            <% } else { %>
              <tr><td colspan="2" style="text-align:center;padding:24px;color:var(--text-muted);">Žádná pravidla — výpadek se nikam neodesílá.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- API klíče -->
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
      <h3>API klíče</h3>
      <form method="post" action="/nastaveni/eshopy/api-klic/vytvorit">
        <input type="hidden" name="shop_id" value="<%= shop.id %>">
        <button type="submit" class="btn btn-outline btn-sm">+ Nový klíč</button>
      </form>
    </div>
    <div class="table-wrapper">
      <table class="data-table">
        <thead><tr><th>Klíč (maskovaný)</th><th>Stav</th><th>Vytvořen</th><th></th></tr></thead>
        <tbody>
          <% keys.forEach(k => { %>
          <tr>
            <td><code style="background:var(--gray-100);padding:2px 6px;border-radius:4px;font-size:12px;"><%= k.key.substring(0,8) %>••••••••</code></td>
            <td>
              <% if (k.active) { %><span class="badge" style="background:#dcfce7;color:#166534;">Aktivní</span>
              <% } else { %><span class="badge" style="background:var(--gray-100);color:var(--gray-500);">Neaktivní</span><% } %>
            </td>
            <td style="color:var(--text-muted);font-size:13px;"><%= new Date(k.created_at).toLocaleDateString('cs-CZ') %></td>
            <td>
              <% if (k.active) { %>
              <form method="post" action="/nastaveni/eshopy/api-klic/<%= k.id %>/deaktivovat" style="display:inline;">
                <button type="submit" class="btn btn-ghost btn-sm" style="color:var(--danger);" onclick="return confirm('Deaktivovat klíč?')">Deaktivovat</button>
              </form>
              <% } %>
            </td>
          </tr>
          <% }) %>
          <% if (!keys.length) { %>
          <tr><td colspan="4" style="text-align:center;padding:24px;color:var(--text-muted);">Žádné API klíče</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>

  </div>

  <!-- Pravý sloupec -->
  <div>
    <div class="card">
      <div class="card-header">Jak to funguje</div>
      <div class="card-body" style="font-size:12px;color:var(--text-secondary);line-height:1.7;">
        <p>Worker pinguje URL každých <strong>5 minut</strong>.</p>
        <p style="margin-top:8px;">Při výpadku se odešle alert podle pravidel výše — e-mail, Discord nebo <strong>push notifikace</strong> do prohlížeče přihlášených uživatelů (cooldown 1 h).</p>
        <p style="margin-top:8px;">Kanály se správují centrálně v <a href="/nastaveni/healthchecky">Nastavení → Healthchecky</a>.</p>
      </div>
    </div>
  </div>

</div>

<!-- Modal: Přidat healthcheck -->
<div id="modalAddCheck" class="modal-backdrop" onclick="if(event.target===this)this.classList.remove('open')">
  <div class="modal modal-sm">
    <div class="modal-header">
      <h2 class="modal-title">Přidat healthcheck</h2>
      <button class="modal-close" onclick="document.getElementById('modalAddCheck').classList.remove('open')">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <form method="post" action="/nastaveni/healthchecky/vytvorit">
      <input type="hidden" name="shop_id" value="<%= shop.id %>">
      <input type="hidden" name="returnTo" value="/nastaveni/eshopy/<%= shop.id %>">
      <div class="modal-body" style="display:flex;flex-direction:column;gap:14px;">
        <div class="form-group">
          <label class="form-label required">Název</label>
          <input type="text" name="name" class="form-control" value="<%= shop.name %>" required>
        </div>
        <div class="form-group">
          <label class="form-label required">URL</label>
          <input type="url" name="url" class="form-control" placeholder="<%= shop.url %>/api/health" required>
        </div>
        <div class="form-group">
          <label class="form-label">Interval kontrol</label>
          <select name="interval_s" class="form-select">
            <option value="60">1 minuta</option>
            <option value="300" selected>5 minut</option>
            <option value="600">10 minut</option>
            <option value="1800">30 minut</option>
          </select>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-ghost" onclick="document.getElementById('modalAddCheck').classList.remove('open')">Zrušit</button>
        <button type="submit" class="btn btn-primary">Přidat</button>
      </div>
    </form>
  </div>
</div>

<!-- Modal: Přidat alert pravidlo -->
<div id="modalAddRule" class="modal-backdrop" onclick="if(event.target===this)this.classList.remove('open')">
  <div class="modal modal-sm">
    <div class="modal-header">
      <h2 class="modal-title">Přidat alert (App down)</h2>
      <button class="modal-close" onclick="document.getElementById('modalAddRule').classList.remove('open')">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <form method="post" action="/nastaveni/notifikace/pravidlo/vytvorit">
      <input type="hidden" name="event_type" value="app_down">
      <input type="hidden" name="returnTo" value="/nastaveni/eshopy/<%= shop.id %>">
      <div class="modal-body" style="display:flex;flex-direction:column;gap:14px;">
        <div class="form-group">
          <label class="form-label required">Notifikační kanál</label>
          <select name="channel_id" class="form-select" required>
            <% channels.forEach(ch => { %>
            <option value="<%= ch.id %>"><%= ch.name %> (<%= ch.type %>)</option>
            <% }) %>
          </select>
          <small style="color:var(--text-muted);font-size:12px;">Nový kanál (e-mail/Discord/push) se přidává v <a href="/nastaveni/healthchecky">Nastavení → Healthchecky</a>.</small>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-ghost" onclick="document.getElementById('modalAddRule').classList.remove('open')">Zrušit</button>
        <button type="submit" class="btn btn-primary">Přidat</button>
      </div>
    </form>
  </div>
</div>

<script>
document.querySelectorAll('[data-modal-open]').forEach(b =>
  b.addEventListener('click', () => document.getElementById(b.dataset.modalOpen)?.classList.add('open'))
);
</script>
