<div class="page-header">
  <div class="page-header-left">
    <h1>Číselné řady faktur</h1>
    <p>Každý eshop nebo okruh může mít vlastní číselnou řadu</p>
  </div>
  <button class="btn btn-primary" data-modal-open="modalCreate">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    Nová řada
  </button>
</div>

<% if (saved) { %>
<div class="alert alert-success" style="background:#dcfce7;color:#166534;border:1px solid #bbf7d0;padding:12px 16px;border-radius:8px;margin-bottom:20px;">✓ Uloženo</div>
<% } %>

<div class="table-wrapper">
  <table class="data-table">
    <thead>
      <tr>
        <th>Název</th>
        <th>Typ</th>
        <th>Formát</th>
        <th>Eshop</th>
        <th>Aktuální č.</th>
        <th>Začátek</th>
        <th>Stav</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% if (series && series.length > 0) { %>
        <% series.forEach(s => { %>
        <tr>
          <td style="font-weight:500;"><%= s.name %></td>
          <td><%= s.entity_type === 'objednavka' ? 'Objednávka' : 'Faktura' %></td>
          <td>
            <code style="background:var(--gray-100);padding:2px 6px;border-radius:4px;font-size:12px;"><%= s.example %></code>
          </td>
          <td><%= s.shop_name || '—' %></td>
          <td><%= s.current_number %></td>
          <td><%= s.start_number %></td>
          <td>
            <% if (s.active) { %>
              <span class="badge" style="background:#dcfce7;color:#166534;">Aktivní</span>
            <% } else { %>
              <span class="badge" style="background:var(--gray-100);color:var(--gray-500);">Neaktivní</span>
            <% } %>
          </td>
          <td>
            <% if (s.active) { %>
              <form method="post" action="/nastaveni/ciselne-rady/<%= s.id %>/deaktivovat" style="display:inline;">
                <button type="submit" class="btn btn-ghost btn-sm" onclick="return confirm('Deaktivovat řadu <%= s.name %>?')">Deaktivovat</button>
              </form>
            <% } else { %>
              <form method="post" action="/nastaveni/ciselne-rady/<%= s.id %>/aktivovat" style="display:inline;">
                <button type="submit" class="btn btn-ghost btn-sm">Aktivovat</button>
              </form>
            <% } %>
          </td>
        </tr>
        <% }) %>
      <% } else { %>
        <tr><td colspan="8" style="text-align:center;padding:40px;color:var(--text-muted);">Žádné číselné řady. Vytvořte první.</td></tr>
      <% } %>
    </tbody>
  </table>
</div>

<!-- Modal: Nová číselná řada -->
<div id="modalCreate" class="modal-overlay" style="display:none;" onclick="if(event.target===this)this.style.display='none'">
  <div class="modal" style="max-width:500px;width:90%;">
    <div class="modal-header">
      <h3>Nová číselná řada</h3>
      <button class="modal-close" onclick="document.getElementById('modalCreate').style.display='none'">&times;</button>
    </div>
    <form method="post" action="/nastaveni/ciselne-rady/vytvorit">
      <div class="modal-body" style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">

        <div class="form-group" style="grid-column:1/-1;">
          <label class="form-label">Název *</label>
          <input type="text" name="name" class="form-control" placeholder="Toneráček vydané faktury 2026" required>
        </div>

        <div class="form-group" style="grid-column:1/-1;">
          <label class="form-label">Typ řady</label>
          <select name="entity_type" class="form-select">
            <option value="faktura">Faktura</option>
            <option value="objednavka">Objednávka</option>
          </select>
        </div>

        <div class="form-group" style="grid-column:1/-1;">
          <label class="form-label">Vlastní formát (nepovinné)</label>
          <input type="text" name="format" id="seriesFormatInput" class="form-control" placeholder="TC-YYYY-NNN" oninput="seriesFormatPreview()">
          <small style="color:var(--text-muted);">
            Tokeny: <code>YYYY</code>/<code>YY</code> rok, <code>MM</code> měsíc, <code>DD</code> den,
            <code>X</code> náhodná číslice (např. <code>XXX</code> = 3 znaky), <code>N</code> pořadové číslo (např. <code>NNN</code> = 001).
            Pokud je vyplněno, má přednost před prefixem/rokem/počtem číslic níže.
          </small>
          <div style="margin-top:6px;font-size:12px;color:var(--text-muted);">Náhled: <code id="seriesFormatPreview">—</code></div>
        </div>

        <div class="form-group">
          <label class="form-label">Prefix <span id="seriesPrefixReq">*</span></label>
          <input type="text" name="prefix" id="seriesPrefixInput" class="form-control" placeholder="TC" maxlength="10" required style="text-transform:uppercase;">
          <small style="color:var(--text-muted);">Použije se, pokud není vyplněn vlastní formát</small>
        </div>

        <div class="form-group">
          <label class="form-label">Rok (nepovinné)</label>
          <input type="number" name="year" class="form-control" placeholder="2026" min="2020" max="2099">
          <small style="color:var(--text-muted);">Prázdné = bez roku v čísle</small>
        </div>

        <div class="form-group">
          <label class="form-label">Začínat od</label>
          <input type="number" name="start_number" class="form-control" value="1" min="0">
          <small style="color:var(--text-muted);">První číslo v řadě</small>
        </div>

        <div class="form-group">
          <label class="form-label">Počet číslic</label>
          <select name="padding" class="form-select">
            <option value="3">3 (TC-2026-001)</option>
            <option value="4" selected>4 (TC-2026-0001)</option>
            <option value="5">5 (TC-2026-00001)</option>
          </select>
        </div>

        <div class="form-group" style="grid-column:1/-1;">
          <label class="form-label">Přiřadit k eshopu (nepovinné)</label>
          <select name="shop_id" class="form-select">
            <option value="">— Obecná řada —</option>
            <% shops.forEach(sh => { %>
            <option value="<%= sh.id %>"><%= sh.name %></option>
            <% }) %>
          </select>
        </div>

      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-ghost" onclick="document.getElementById('modalCreate').style.display='none'">Zrušit</button>
        <button type="submit" class="btn btn-primary">Vytvořit řadu</button>
      </div>
    </form>
  </div>
</div>

<script>
document.querySelectorAll('[data-modal-open]').forEach(btn => {
  btn.addEventListener('click', () => {
    document.getElementById(btn.dataset.modalOpen).style.display = 'flex';
  });
});

function seriesFormatPreview() {
  const format = document.getElementById('seriesFormatInput').value.trim();
  const prefixInput = document.getElementById('seriesPrefixInput');
  const prefixReq   = document.getElementById('seriesPrefixReq');
  const out = document.getElementById('seriesFormatPreview');
  prefixInput.required = !format;
  prefixReq.style.display = format ? 'none' : 'inline';
  if (!format) { out.textContent = '—'; return; }
  const now = new Date();
  out.textContent = format.replace(/Y{4}|Y{2}|M{2}|D{2}|X+|N+/g, token => {
    if (token === 'YYYY') return String(now.getFullYear());
    if (token === 'YY')   return String(now.getFullYear()).slice(-2);
    if (token === 'MM')   return String(now.getMonth() + 1).padStart(2, '0');
    if (token === 'DD')   return String(now.getDate()).padStart(2, '0');
    if (token[0] === 'X') return '#'.repeat(token.length);
    if (token[0] === 'N') return '1'.padStart(token.length, '0');
    return token;
  });
}
</script>
