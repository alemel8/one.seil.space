<%
  const statusColor = s => ({
    'Aktivní':      ['var(--success-bg)', '#166534'],
    'Pozastaveno':  ['var(--warning-bg)', '#92400e'],
    'Dokončeno':    ['var(--info-bg)',    '#1e40af'],
    'Archivováno':  ['var(--gray-100)',   'var(--gray-600)'],
  }[s] || ['var(--gray-100)', 'var(--gray-600)']);
%>

<div class="page-header">
  <div class="page-header-left">
    <h1>Projekty</h1>
    <p><%= projects.length %> projektů</p>
  </div>
  <button class="btn btn-primary" data-modal-open="modalCreateProject">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    Nový projekt
  </button>
</div>

<!-- Hledání + filtr -->
<form method="get" style="display:flex;gap:10px;margin-bottom:20px;flex-wrap:wrap;">
  <div style="position:relative;flex:1;min-width:240px;max-width:380px;">
    <svg style="position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--text-muted);" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
    </svg>
    <input type="text" name="q" value="<%= q || '' %>" placeholder="Hledat projekt, klienta…" class="form-control" style="padding-left:38px;">
  </div>
  <select name="status" class="form-select" style="width:auto;">
    <option value="">Všechny stavy</option>
    <% PROJECT_STATUSES.forEach(s => { %>
    <option value="<%= s %>" <%= statusFilter === s ? 'selected' : '' %>><%= s %></option>
    <% }) %>
  </select>
  <button type="submit" class="btn btn-outline">Filtrovat</button>
  <% if (q || statusFilter) { %>
    <a href="/projekty" class="btn btn-ghost">Zrušit filtr</a>
  <% } %>
</form>

<% if (projects.length > 0) { %>
<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:16px;">
  <% projects.forEach(p => { const sc = statusColor(p.status); const types = (p.item_types || []).filter(Boolean); %>
  <div class="card kpi-link" style="cursor:pointer;" onclick="location.href='/projekty/<%= p.id %>'">
    <div class="card-body" style="display:flex;flex-direction:column;gap:12px;">
      <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:8px;">
        <div style="min-width:0;">
          <div style="font-weight:600;font-size:15px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= p.name %></div>
          <div style="font-size:12px;color:var(--text-muted);margin-top:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= p.company_name %></div>
        </div>
        <span class="badge" style="background:<%= sc[0] %>;color:<%= sc[1] %>;flex-shrink:0;"><%= p.status %></span>
      </div>
      <div style="display:flex;align-items:center;justify-content:space-between;">
        <div style="display:flex;gap:6px;">
          <% types.slice(0, 6).forEach(t => { const meta = PROJECT_TYPES[t]; if (!meta) return; %>
          <span class="project-type-icon" style="--icon-url:url(/static/img/project-types/<%= meta.icon %>);--icon-color:<%= meta.color %>;" title="<%= meta.label %>"></span>
          <% }) %>
        </div>
        <span style="font-size:12px;color:var(--text-muted);"><%= p.item_count %> podprojekt<%= p.item_count === 1 ? '' : (p.item_count >= 2 && p.item_count <= 4 ? 'y' : 'ů') %></span>
      </div>
    </div>
  </div>
  <% }) %>
</div>
<% } else { %>
<div style="text-align:center;padding:64px;color:var(--text-muted);">
  <%= (q || statusFilter) ? 'Žádné projekty nenalezeny' : 'Zatím žádné projekty. Založte první tlačítkem výše.' %>
</div>
<% } %>

<!-- Modal: Nový projekt -->
<div class="modal-backdrop" id="modalCreateProject">
  <div class="modal modal-sm">
    <div class="modal-header">
      <h2 class="modal-title">Nový projekt</h2>
      <button class="modal-close" data-modal-close="modalCreateProject">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <form method="post" action="/projekty/vytvorit">
      <div class="modal-body" style="display:flex;flex-direction:column;gap:14px;">
        <div class="form-group">
          <label class="form-label required">Klient (z CRM)</label>
          <select name="company_id" class="form-select" required>
            <option value="">— vyberte firmu —</option>
            <% companies.forEach(c => { %>
            <option value="<%= c.id %>"><%= c.name %></option>
            <% }) %>
          </select>
          <% if (companies.length === 0) { %>
          <div style="font-size:12px;color:var(--text-muted);margin-top:4px;">Žádné firmy v CRM — <a href="/crm/firmy" style="color:var(--primary);">nejprve založte firmu</a>.</div>
          <% } %>
        </div>
        <div class="form-group">
          <label class="form-label">Název projektu</label>
          <input type="text" name="name" class="form-control" placeholder="Ponechte prázdné pro název klienta">
        </div>
        <div class="form-group">
          <label class="form-label">Stav</label>
          <select name="status" class="form-select">
            <% PROJECT_STATUSES.forEach(s => { %><option value="<%= s %>" <%= s === 'Aktivní' ? 'selected' : '' %>><%= s %></option><% }) %>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Datum zahájení</label>
          <input type="date" name="start_date" class="form-control">
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline" data-modal-close="modalCreateProject">Zrušit</button>
        <button type="submit" class="btn btn-primary">Založit projekt</button>
      </div>
    </form>
  </div>
</div>
