<aside class="sidebar" id="sidebar">

  <!-- Logo → homepage -->
  <a href="/" class="sidebar-logo" style="text-decoration:none;">
    <img src="/static/img/logo-white.png" alt="SEIL" class="sidebar-logo-img">
  </a>

  <!-- Navigace -->
  <nav class="sidebar-nav">

    <!-- DOMOVSKÁ STRÁNKA -->
    <div class="nav-section">
      <div class="nav-item">
        <a href="/" class="nav-link <%= currentPath === '/' ? 'active' : '' %>" style="text-decoration:none;">
          <span class="nav-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
              <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
          </span>
          <span class="nav-label">Domovská stránka</span>
        </a>
      </div>
    </div>

    <!-- MONITORING -->
    <div class="nav-section">
      <div class="nav-section-label">Monitoring</div>

      <div class="nav-item <%= currentPath === '/monitoring' ? 'open' : '' %>">
        <button class="nav-link" data-toggle="sub">
          <span class="nav-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
              <rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
            </svg>
          </span>
          <span class="nav-label">Monitoring</span>
          <svg class="nav-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6"/>
          </svg>
        </button>
        <ul class="nav-sub">
          <li>
            <a href="/monitoring" class="nav-sub-link <%= currentPath === '/monitoring' ? 'active' : '' %>">
              Aktuální stav VPS
            </a>
          </li>
          <% if (user && user.is_admin) { %>
          <li>
            <a href="/nastaveni/healthchecky" class="nav-sub-link <%= currentPath === '/nastaveni/healthchecky' ? 'active' : '' %>">
              Healthchecky &amp; notifikace
            </a>
          </li>
          <% } %>
        </ul>
      </div>
    </div>

    <!-- ÚČETNICTVÍ -->
    <div class="nav-section">
      <div class="nav-section-label">Účetnictví</div>

      <div class="nav-item <%= currentPath && currentPath.startsWith('/ucetnictvi') ? 'open' : '' %>">
        <button class="nav-link" data-toggle="sub">
          <span class="nav-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
            </svg>
          </span>
          <span class="nav-label">Účetnictví</span>
          <svg class="nav-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6"/>
          </svg>
        </button>
        <ul class="nav-sub">
          <li>
            <a href="/ucetnictvi/prehled" class="nav-sub-link <%= currentPath === '/ucetnictvi/prehled' ? 'active' : '' %>">
              Finanční přehled
            </a>
          </li>
          <li>
            <a href="/ucetnictvi/objednavky" class="nav-sub-link <%= currentPath && currentPath.startsWith('/ucetnictvi/objednavky') ? 'active' : '' %>">
              Objednávky
            </a>
          </li>
          <li>
            <a href="/ucetnictvi/prijate-faktury" class="nav-sub-link <%= currentPath && currentPath.startsWith('/ucetnictvi/prijate-faktury') ? 'active' : '' %>">
              Přijaté faktury
            </a>
          </li>
          <li>
            <a href="/ucetnictvi/vydane-faktury" class="nav-sub-link <%= currentPath && currentPath.startsWith('/ucetnictvi/vydane-faktury') ? 'active' : '' %>">
              Vydané faktury
            </a>
          </li>
          <li>
            <a href="/ucetnictvi/sablony-faktur" class="nav-sub-link <%= currentPath === '/ucetnictvi/sablony-faktur' ? 'active' : '' %>">
              Šablony faktur
            </a>
          </li>
          <li>
            <a href="/ucetnictvi/uctenky" class="nav-sub-link <%= currentPath && currentPath.startsWith('/ucetnictvi/uctenky') ? 'active' : '' %>">
              Účtenky
            </a>
          </li>
          <li>
            <a href="/ucetnictvi/banka" class="nav-sub-link <%= currentPath === '/ucetnictvi/banka' ? 'active' : '' %>">
              Banka
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- CRM -->
    <div class="nav-section">
      <div class="nav-section-label">CRM</div>

      <div class="nav-item <%= currentPath && currentPath.startsWith('/crm') ? 'open' : '' %>">
        <button class="nav-link" data-toggle="sub">
          <span class="nav-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </span>
          <span class="nav-label">CRM</span>
          <svg class="nav-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6"/>
          </svg>
        </button>
        <ul class="nav-sub">
          <li>
            <a href="/crm/firmy" class="nav-sub-link <%= currentPath && currentPath.startsWith('/crm/firmy') ? 'active' : '' %>">
              Firmy
            </a>
          </li>
          <li>
            <a href="/crm/kontakty" class="nav-sub-link <%= currentPath && currentPath.startsWith('/crm/kontakty') ? 'active' : '' %>">
              Kontakty
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- NASTAVENÍ (pouze admin) -->
    <% if (user && user.is_admin) { %>
    <div class="nav-section">
      <div class="nav-section-label">Nastavení</div>
      <div class="nav-item <%= currentPath && currentPath.startsWith('/nastaveni') ? 'open' : '' %>">
        <button class="nav-link" data-toggle="sub">
          <span class="nav-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
            </svg>
          </span>
          <span class="nav-label">Nastavení</span>
          <svg class="nav-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
        <ul class="nav-sub">
          <li><a href="/nastaveni/firma" class="nav-sub-link <%= currentPath === '/nastaveni/firma' ? 'active' : '' %>">Nastavení firmy</a></li>
          <li><a href="/nastaveni/ciselne-rady" class="nav-sub-link <%= currentPath === '/nastaveni/ciselne-rady' ? 'active' : '' %>">Číselné řady</a></li>
          <li><a href="/nastaveni/ucetni-osnova" class="nav-sub-link <%= currentPath === '/nastaveni/ucetni-osnova' ? 'active' : '' %>">Účetní osnova</a></li>
          <li><a href="/nastaveni/eshopy" class="nav-sub-link <%= currentPath === '/nastaveni/eshopy' ? 'active' : '' %>">Eshopy &amp; API klíče</a></li>
          <li><a href="/api/docs" class="nav-sub-link" target="_blank">API dokumentace ↗</a></li>
        </ul>
      </div>
    </div>
    <% } %>

    <!-- LIDÉ & KULTURA (pouze admin) -->
    <% if (user && user.is_admin) { %>
    <div class="nav-section">
      <div class="nav-section-label">Lidé &amp; Kultura</div>

      <div class="nav-item <%= currentPath && currentPath.startsWith('/lide') ? 'open' : '' %>">
        <button class="nav-link" data-toggle="sub">
          <span class="nav-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
            </svg>
          </span>
          <span class="nav-label">Lidé &amp; Kultura</span>
          <svg class="nav-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6"/>
          </svg>
        </button>
        <ul class="nav-sub">
          <li>
            <a href="/lide/tym" class="nav-sub-link <%= currentPath === '/lide/tym' ? 'active' : '' %>">
              Tým
            </a>
          </li>
        </ul>
      </div>
    </div>
    <% } %>

  </nav>

  <!-- Footer: přihlášený uživatel -->
  <div class="sidebar-footer">
    <a href="/profil" class="sidebar-user">
      <div class="sidebar-avatar">
        <% if (user && user.photo) { %>
          <img src="/media/<%= user.photo %>" alt="">
        <% } else if (user) { %>
          <%= (user.first_name || '').charAt(0).toUpperCase() %><%= (user.last_name || '').charAt(0).toUpperCase() || (user.email || '').charAt(0).toUpperCase() %>
        <% } %>
      </div>
      <div class="sidebar-user-info">
        <div class="sidebar-user-name"><%= user ? ((user.first_name + ' ' + user.last_name).trim() || user.email) : '' %></div>
        <div class="sidebar-user-role"><%= user && user.is_admin ? 'Správce' : 'Uživatel' %></div>
      </div>
    </a>
  </div>

</aside>
